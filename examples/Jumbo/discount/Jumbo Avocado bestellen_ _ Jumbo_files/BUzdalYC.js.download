e",value:"printReceipt"},arguments:[],directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"name"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"givenName"},arguments:[],directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"termsAndConditions"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"general"},arguments:[],directives:[]}]}}]}},{kind:"Field",alias:{kind:"Name",value:"extrasDigitalStamps"},name:{kind:"Name",value:"getDigitalStamps"},arguments:[],directives:[{kind:"Directive",name:{kind:"Name",value:"include"},arguments:[{kind:"Argument",name:{kind:"Name",value:"if"},value:{kind:"Variable",name:{kind:"Name",value:"fetchExtrasInfo"}}}]}],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"optInStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"digitalStamps"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"numberStamps"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"campaignId"},arguments:[],directives:[]}]}}]}},{kind:"Field",alias:{kind:"Name",value:"campaigns"},name:{kind:"Name",value:"getCampaigns"},arguments:[{kind:"Argument",name:{kind:"Name",value:"active"},value:{kind:"BooleanValue",value:!0}},{kind:"Argument",name:{kind:"Name",value:"campaignType"},value:{kind:"StringValue",value:"SAVING",block:!1}}],directives:[{kind:"Directive",name:{kind:"Name",value:"include"},arguments:[{kind:"Argument",name:{kind:"Name",value:"if"},value:{kind:"Variable",name:{kind:"Name",value:"fetchExtrasInfo"}}}]}],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"campaignData"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"accountId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"numberOfStampsPerCard"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"stampImage"},arguments:[],directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"title"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"campaignCode"},arguments:[],directives:[]}]}}]}}],loc:{start:0,end:2408}};X9.loc.source={body:`query UserDetails($customerId: String, $fetchExtrasInfo: Boolean!, $fetchPaymentMethod: Boolean!) {
  cdmCustomer(customerId: $customerId) {
    contactInformation {
      name {
        firstName
        middleName
        lastName
      }
      addresses {
        unit
        apartment
        postalCode
        street
        type
        city
        countryCode
      }
      telephones {
        type
        number
      }
      gender
      email
      dateOfBirth
    }
    preference {
      newsletter {
        marketing
        inspiration
        extras
      }
      pushNotifications {
        transactional
        commercial
        sms
      }
      termsAndConditions {
        eCommerce
        loyalty
      }
      personalization {
        avgLoyalty
        avgEcommerce
      }
      dietary {
        active
        noCelery
        noCrustacean
        noEgg
        noFish
        noGluten
        noLactose
        noLupin
        noMilk
        noMolluscs
        noMustard
        noPeanut
        noSesame
        noSoy
        noSulphites
        noTreenut
        noWheat
      }
      testPanel {
        jott
      }
      communication {
        deliveryNote
      }
      store {
        homeStore {
          complexNumber
          storeDetails {
            addressName
            city
            street
            street2
            street3
          }
        }
      }
    }
    b2bDetails {
      b2bInfo {
        businessPartnerNumber
      }
    }
    b2bDetails @include(if: $fetchPaymentMethod) {
      b2bInfo {
        paymentMethod
        businessPartnerNumber
      }
      b2bSubInfo {
        b2bMasterDetails {
          paymentMethod
        }
      }
    }
  }
  extrasBalance: getBalance @include(if: $fetchExtrasInfo) {
    balance
  }
  extrasProfile: getProfile @include(if: $fetchExtrasInfo) {
    loyaltyCard {
      number
    }
    checkoutPreferences {
      printReceipt
    }
    name {
      givenName
    }
    termsAndConditions {
      general
    }
  }
  extrasDigitalStamps: getDigitalStamps @include(if: $fetchExtrasInfo) {
    optInStatus
    digitalStamps {
      numberStamps
      campaignId
    }
  }
  campaigns: getCampaigns(active: true, campaignType: "SAVING") @include(if: $fetchExtrasInfo) {
    campaignData {
      accountId
      numberOfStampsPerCard
      stampImage
    }
    title
    campaignCode
  }
}

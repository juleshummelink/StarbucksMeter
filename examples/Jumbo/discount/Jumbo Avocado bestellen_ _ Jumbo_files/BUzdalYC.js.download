"digitalStamps"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"numberStamps"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"campaignId"},arguments:[],directives:[]}]}}]}},{kind:"Field",alias:{kind:"Name",value:"campaigns"},name:{kind:"Name",value:"getCampaigns"},arguments:[{kind:"Argument",name:{kind:"Name",value:"active"},value:{kind:"BooleanValue",value:!0}},{kind:"Argument",name:{kind:"Name",value:"campaignType"},value:{kind:"StringValue",value:"SAVING",block:!1}}],directives:[{kind:"Directive",name:{kind:"Name",value:"include"},arguments:[{kind:"Argument",name:{kind:"Name",value:"if"},value:{kind:"Variable",name:{kind:"Name",value:"fetchExtrasInfo"}}}]}],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"campaignData"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"accountId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"numberOfStampsPerCard"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"stampImage"},arguments:[],directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"title"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"campaignCode"},arguments:[],directives:[]}]}}]}}],loc:{start:0,end:3495}};v5.loc.source={body:`query CustomerDetails($customerId: ID!, $fetchExtrasInfo: Boolean!, $fetchPaymentMethod: Boolean!, $fetchSubAccounts: Boolean! = false) {
  customer(id: $customerId) {
    contactInformation {
      name {
        firstName
        middleName
        lastName
      }
      addresses {
        houseNumber # < unit
        addition # < appartment
        postalCode
        street
        typeCode # < type
        city
        country # < countryCode
      }
      telephones {
        type
        number
      }
      #   gender < missing in the new API
      email
      dateOfBirth
    }
    customerPreference {
      # < preference
      newsletter {
        marketing
        inspiration
        extras
        ecom
      }
      pushNotifications {
        transactional
        inspiration
        sms
        ecom
        extras
      }
      termsAndConditions {
        eCommerce
        loyalty
        audienceSharing # new!
      }
      personalization {
        avgLoyalty
        avgEcommerce
      }
      checkout {
        promotionStamps
      }
      dietary {
        active
        noCelery
        noCrustacean
        noEgg
        noFish
        noGluten
        noLactose
        noLupin
        noMilk
        noMolluscs
        noMustard
        noPeanut
        noSesame
        noSoy
        noSulphites
        noTreenut
        noWheat
      }
      testPanel {
        jott
      }
      communication {
        deliveryNote
      }
      store {
        homeStore {
          complexNumber
          name # new
          city # new
          #       storeDetails { < missing in the new API
          #         addressName
          #         city
          #         street
          #         street2
          #         street3
          #       }
        }
      }
    }
    b2bDetails @include(if: $fetchPaymentMethod) {
      b2bInfo {
        paymentMethod
        businessPartnerNumber
        chamberOfCommerceDetails {
          kvkNumber
        }
        companyName
      }
      b2bSubInfo {
        b2bMasterDetail {
          email
          id
          paymentMethod
        }
        branchName
      }
    }
    subAccounts @include(if: $fetchSubAccounts) {
      customerId
      status
      username
      contactInformation {
        email
        dateOfBirth
        addresses {
          houseNumber
          addition
          postalCode
          street
          typeCode
          city
          country
        }
        telephones {
          type
          number
        }
        name {
          firstName
          middleName
          lastName
        }
      }
      b2bDetails {
        b2bSubInfo {
          branchName
        }
      }
    }
  }
  extrasBalance: getBalance @include(if: $fetchExtrasInfo) {
    balance
  }
  extrasProfile: getProfile @include(if: $fetchExtrasInfo) {
    loyaltyCard {
      number
    }
    name {
      givenName
    }
    termsAndConditions {
      general
    }
    checkoutPreferences {
      printReceipt
    }
    digitalStamps {
      optIn
    }
    checkoutPreferences {
      printReceipt
    }
  }
  extrasDigitalStamps: getDigitalStamps @include(if: $fetchExtrasInfo) {
    optInStatus
    digitalStamps {
      numberStamps
      campaignId
    }
  }
  campaigns: getCampaigns(active: true, campaignType: "SAVING") @include(if: $fetchExtrasInfo) {
    campaignData {
      accountId
      numberOfStampsPerCard
      stampImage
    }
    title
    campaignCode
  }
}

#import "@fep/core/graphql/fragments/store.gql"

mutation CheckoutPlaceOrder($input: CheckoutPlaceOrderInput!) {
  checkoutPlaceOrder(input: $input) {
    order {
      orderId
      fulfilmentType
      deliveryPeriod {
        ...ReservedDeliveryPeriod
      }
      storeV2 {
        ...Store
      }
    }

#import "@basket/graphql/fragments/error.gql"

mutation BasketPageAddBasketItems(
  $input: AddBasketLinesInput!
  $voucherCodes: [String!]
  $shippingCosts: MoneyTypeInput
  $orderChannel: OrderChannel!
  $customerId: String
) {
  addBasketLines(input: $input) {
    ... on Basket {
      ...FullBasket
    }

    ... on Error {
      ...Error
    }

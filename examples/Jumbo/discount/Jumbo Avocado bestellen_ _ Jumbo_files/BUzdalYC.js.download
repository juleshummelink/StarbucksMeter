#import "@fep/core/graphql/fragments/money-type.gql"
#import "@fep/core/graphql/fragments/calculation/calculated-free-gift.gql"
#import "@fep/core/graphql/fragments/calculation/calculated-promotion.gql"
#import "@basket/graphql/fragments/calculation-result/calculated-deposit/calculated-deposit.gql"
#import "@basket/graphql/fragments/calculation-result/calculated-item/calculated-item.gql"

fragment CalculationResult on CalculationResult {
  totals {
    itemSubtotal {
      ...MoneyType
    }
    itemTotal {
      ...MoneyType
    }
    nonItemTotal {
      ...MoneyType
    }
    deposit {
      ...CalculatedDeposit
    }
    shippingCosts {
      ...MoneyType
    }
    totalToPay {
      ...MoneyType
    }
    itemsDepositGroups {
      quantity
      total {
        ...MoneyType
      }
      description
    }
    discounts {
      items {
        ...MoneyType
      }
      itemsExcludingDiscountFromVouchers {
        ...MoneyType
      }
      order {
        ...MoneyType
      }
      shipping {
        ...MoneyType
      }
      totalDiscounts {
        ...MoneyType
      }
    }
    taxes {
      groups {
        amount {
          ...MoneyType
        }
        code
      }
      totalTaxes {
        ...MoneyType
      }
    }
    surcharges {
      singleUsePlastic {
        ...MoneyType
      }
      totalSurcharges {
        ...MoneyType
      }
    }
  }
  items {
    ...CalculatedItem
  }
  promotions {
    ...CalculatedPromotion
  }
  freeGifts {
    ...CalculatedFreeGift
  }
  checkoutMinimumOrderValue(channel: $orderChannel, customerId: $customerId) {
    ... on CheckoutMinimumOrderValue {
      ...MinimumOrderValue
    }
    ... on CheckoutServiceError {
      message
    }
  }
}

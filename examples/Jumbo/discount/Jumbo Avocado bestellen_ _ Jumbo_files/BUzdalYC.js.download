#import "@fep/core/graphql/fragments/address.gql"
#import "@fep/core/graphql/fragments/store.gql"

fragment Order on Order {
  orderId
  deliveryDate
  fulfilmentType
  hasAgeRestrictedItems
  progress {
    cutoffTime
    orderChannel
    status
  }
  totals {
    shippingCosts {
      ...MoneyType
    }
  }
  progressHelpers {
    isCancelled
    isClosed
    isCompleted
  }
  fulfilmentData {
    reservationId
    startTime
    endTime
    displayAddress {
      ...Address
    }
    storeV2 {
      ...Store
    }
  }
  promotions {
    description
    discount {
      ...MoneyType
    }
    voucherCode
  }
}

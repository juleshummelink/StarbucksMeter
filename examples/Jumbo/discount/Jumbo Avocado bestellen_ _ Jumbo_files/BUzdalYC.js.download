    query getRecipeLists($itemsInput: RecipeListFindItemsInput, $listsSize: Int, $listsPage: Int, $recipeId: ID, $includeHasRecipe: Boolean = false) {
  favouriteLists: recipeListsV2(
    input: {type: FAVORITE_LIST, size: $listsSize, page: $listsPage}
  ) {
    items {
      totalRecipes
      hasRecipe(recipeId: $recipeId) @include(if: $includeHasRecipe)
      type
      title
      id
      items(input: $itemsInput) {
        recipeListItems {
          recipe {
            fullImageUrl
            title
          }
        }
      }
    }
    paginationInfo {
      pageSize
      currentPage
      totalPages
      totalSize
      hasPreviousPage
      hasNextPage
    }
  }
  customerLists: recipeListsV2(
    input: {type: CATEGORY, size: $listsSize, page: $listsPage}
  ) {
    items {
      totalRecipes
      hasRecipe(recipeId: $recipeId) @include(if: $includeHasRecipe)
      type
      title
      id
      items(input: $itemsInput) {
        recipeListItems {
          recipe {
            fullImageUrl
            title
          }
        }
      }
    }
    paginationInfo {
      pageSize
      currentPage
      totalPages
      totalSize
      hasPreviousPage
      hasNextPage
    }
  }
}

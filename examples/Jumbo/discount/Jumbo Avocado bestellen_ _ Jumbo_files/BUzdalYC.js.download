  sku
  title
  subtitle
  brand
  image
  link
  ageRestriction
  dataProcessingRestricted
  retailSet
  id: sku
  category
  isExcludedForCustomer
  price {
    price
    promoPrice
    pricePerUnit {
      price
      quantity
      unit
    }
  }
  availability {
    availability
    isAvailable
    label
    reason
    stockLimit
  }
  quantityDetails {
    defaultAmount
    maxAmount
    minAmount
    stepAmount
    unit
  }
  primaryProductBadges {
    alt
    image
  }
  secondaryProductBadges {
    alt
    image
  }
  promotions {
    id
    start {
      dayShort
      date
      monthShort
    }
    end {
      dayShort
      date
      monthShort
    }
    tags {
      text
      inverse
    }
    isKiesAndMix
    maxPromotionQuantity
    url
  }
  list {
    isInCustomerList
  }
}

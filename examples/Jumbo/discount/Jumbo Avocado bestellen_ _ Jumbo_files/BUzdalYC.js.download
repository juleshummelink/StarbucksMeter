#import "@basket/graphql/fragments/calculation-result/calculation-result.gql"

fragment FullBasket on Basket {
  ...Basket

  calculation(voucherCodes: $voucherCodes, shippingCosts: $shippingCosts) {
    ...CalculationResult
  }
}

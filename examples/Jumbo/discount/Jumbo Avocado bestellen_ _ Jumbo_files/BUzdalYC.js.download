  products(skus: $skus) {
    title
    sku
    id: sku
    dataProcessingRestricted
    price {
      price
      pricePerUnit {
        price
      }
      promoPrice
      sku
    }
    image
    badges {
      type
      description
      startDate
      endDate
      position
      path
      name
    }
    allergies {
      id
    }
    additionalImages {
      image
    }
    availability {
      availability
      availabilityNote
      cutoffDate
      efcId
      isAvailable
      label
      reason
      referenceDate
      sku
      status
      stockLimit
      storeId
    }
    link
    promotions {
      tags {
        text
      }
    }
  }
}

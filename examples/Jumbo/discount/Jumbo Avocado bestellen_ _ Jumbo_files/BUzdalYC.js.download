    query CustomerDetails($customerId: ID!, $fetchExtrasInfo: Boolean!, $fetchPaymentMethod: Boolean!, $fetchSubAccounts: Boolean! = false) {
  customer(id: $customerId) {
    contactInformation {
      name {
        firstName
        middleName
        lastName
      }
      addresses {
        houseNumber
        addition
        postalCode
        street
        typeCode
        city
        country
      }
      telephones {
        type
        number
      }
      email
      dateOfBirth
    }
    customerPreference {
      newsletter {
        marketing
        inspiration
        extras
        ecom
      }
      pushNotifications {
        transactional
        inspiration
        sms
        ecom
        extras
      }
      termsAndConditions {
        eCommerce
        loyalty
        audienceSharing
      }
      personalization {
        avgLoyalty
        avgEcommerce
      }
      checkout {
        promotionStamps
      }
      dietary {
        active
        noCelery
        noCrustacean
        noEgg
        noFish
        noGluten
        noLactose
        noLupin
        noMilk
        noMolluscs
        noMustard
        noPeanut
        noSesame
        noSoy
        noSulphites
        noTreenut
        noWheat
      }
      testPanel {
        jott
      }
      communication {
        deliveryNote
      }
      store {
        homeStore {
          complexNumber
          name
          city
        }
      }
    }
    b2bDetails @include(if: $fetchPaymentMethod) {
      b2bInfo {
        paymentMethod
        businessPartnerNumber
        chamberOfCommerceDetails {
          kvkNumber
        }
        companyName
      }
      b2bSubInfo {
        b2bMasterDetail {
          email
          id
          paymentMethod
        }
        branchName
      }
    }
    subAccounts @include(if: $fetchSubAccounts) {
      customerId
      status
      username
      contactInformation {
        email
        dateOfBirth
        addresses {
          houseNumber
          addition
          postalCode
          street
          typeCode
          city
          country
        }
        telephones {
          type
          number
        }
        name {
          firstName
          middleName
          lastName
        }
      }
      b2bDetails {
        b2bSubInfo {
          branchName
        }
      }
    }
  }
  extrasBalance: getBalance @include(if: $fetchExtrasInfo) {
    balance
  }
  extrasProfile: getProfile @include(if: $fetchExtrasInfo) {
    loyaltyCard {
      number
    }
    name {
      givenName
    }
    termsAndConditions {
      general
    }
    checkoutPreferences {
      printReceipt
    }
    digitalStamps {
      optIn
    }
    checkoutPreferences {
      printReceipt
    }
  }
  extrasDigitalStamps: getDigitalStamps @include(if: $fetchExtrasInfo) {
    optInStatus
    digitalStamps {
      numberStamps
      campaignId
    }
  }
  campaigns: getCampaigns(active: true, campaignType: "SAVING") @include(if: $fetchExtrasInfo) {
    campaignData {
      accountId
      numberOfStampsPerCard
      stampImage
    }
    title
    campaignCode
  }
}

fragment CalculatedItem on CalculatedItems {
  basePrice {
    ...MoneyType
  }
  capturePriceOnPick
  context {
    date
    storeId
  }
  deposit {
    quantity
    sku
    unitPrice {
      ...MoneyType
    }
  }
  linePriceExDiscount {
    ...MoneyType
  }
  linePriceIncDiscount {
    ...MoneyType
  }
  name
  promotions {
    description
    discount {
      ...MoneyType
    }
    id
    scope
    type
    voucherCode
  }
  quantity
  lineId: requestLineId
  shippingCosts {
    ...MoneyType
  }
  shippingTaxAmount {
    ...MoneyType
  }
  sku
  tax {
    amount {
      ...MoneyType
    }
    code
  }
  totalPrice {
    ...MoneyType
  }
  unitPrice {
    ...MoneyType
  }
  surcharges {
    type
    value {
      ...MoneyType
    }
  }
}

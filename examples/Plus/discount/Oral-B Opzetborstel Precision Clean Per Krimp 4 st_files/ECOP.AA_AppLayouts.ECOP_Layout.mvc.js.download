return function ($actions, $roles, $public) {
$actions.Callback_AccessValidation.__notDisposed = true;

setTimeout(
    () => {
      $actions.Access_Validation().then(
        (result) => {
                if ($actions.Callback_AccessValidation && $actions.Callback_AccessValidation.__notDisposed) {
                    $actions.Callback_AccessValidation(result.IsMaintenanceScreenEnabled);
                }
        }
      );
    },
0);
};
});

Controller.prototype._onClick_ToggleStorePicker_Sidebar$Action = function (isOpenIn, clearProductSKUClientIn, callContext) {
var model = this.model;
var controller = this.controller;
var idService = this.idService;
controller.ensureControllerAlive("OnClick_ToggleStorePicker_Sidebar");
callContext = controller.callContext(callContext);
var vars = new OS.DataTypes.VariableHolder(new (controller.constructor.getVariableGroupType("ECOP.AA_AppLayouts.ECOP_Layout.OnClick_ToggleStorePicker_Sidebar$vars"))());
vars.value.isOpenInLocal = isOpenIn;
vars.value.clearProductSKUClientInLocal = clearProductSKUClientIn;
if((vars.value.clearProductSKUClientInLocal)) {
// Execute Action: ClearClientVar_ClickedProductSKU
ECP_Cart_CWController.default.clearClientVar_ClickedProductSKU$Action(callContext);
}

// Not phone?
if((!(ECOPClientVariables.getIsPhone()))) {
// Is opened?
if((vars.value.isOpenInLocal)) {
// Execute Action: SidebarOpen
PLUS_OutSystemsUI_2_8_0Controller.default.sidebarOpen$Action(idService.getId("StorePickerSidebar"), callContext);
} else {
// Execute Action: SidebarClose
PLUS_OutSystemsUI_2_8_0Controller.default.sidebarClose$Action(idService.getId("StorePickerSidebar"), callContext);
}

} else {
// Is opened?
if((vars.value.isOpenInLocal)) {
// Execute Action: Toggle_ShowStorePicker_Variable_True
controller._toggle_ShowStorePicker_Variable$Action(true, callContext);
// Execute Action: ToggleSideMenu2
PLUS_OutSystemsUI_2_8_0Controller.default.toggleSideMenu$Action(callContext);
// Execute Action: OpenStorePickerMenuItem
ECOP_Base_RPatController.default.jS_ExecuteObjFunction$Action(model.variables.jS_OpenMenuStorePickerVar, callContext);
// Used to fix an issue with the menu item closing automatically.
controller.safeExecuteJSNode(ECOP_AA_AppLayouts_ECOP_Layout_mvc_controller_OnClick_ToggleStorePicker_Sidebar_OpenStorePickerWithDelayJS, "OpenStorePickerWithDelay", "OnClick_ToggleStorePicker_Sidebar", {
FuncObj: OS.DataConversion.JSNodeParamConverter.to(model.variables.jS_OpenMenuStorePickerVar, OS.Types.Object)
}, function ($parameters) {
}, {
JS_ExecuteObjFunction: ECOP_Base_RPatController.default.clientActionProxies.jS_ExecuteObjFunction$Action
}, {});
} else {
// Execute Action: Toggle_ShowStorePicker_Variable_False
controller._toggle_ShowStorePicker_Variable$Action(false, callContext);
// Execute Action: ToggleSideMenu
PLUS_OutSystemsUI_2_8_0Controller.default.toggleSideMenu$Action(callContext);
}

}

};

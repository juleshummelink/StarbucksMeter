define("ECOP_Reactive_Pat.CustomPatterns.AddRemoveProduct.mvc$controller.OnReady.AddStopPropagationJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let container = document.getElementById($parameters.ContainerId);

container.addEventListener("click", function(event){
        event.stopPropagation();
        event.preventDefault();
});

let columnsWidget = document.getElementById($parameters.ColumnsWidgetId);
columnsWidget.addEventListener("click", function(event){
    if(event.target === event.currentTarget.firstChild) {
        event.stopPropagation();
        event.preventDefault();
    }    
});

let disabledAddButton = document.getElementById($parameters.DisabledAddButtonId);
if (disabledAddButton) {
    disabledAddButton.addEventListener("click", function(event) {
        event.stopPropagation();
        event.preventDefault();
    });
}
};
});

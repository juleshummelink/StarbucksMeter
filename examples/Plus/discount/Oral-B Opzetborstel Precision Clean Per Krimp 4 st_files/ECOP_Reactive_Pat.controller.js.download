define("ECOP_Reactive_Pat.controller$GetCookie.GetCookieJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var cookie_fullname = $parameters.CookieName + "=";
var all_cookies = document.cookie.split(';');
for(var i=0; i < all_cookies.length; i++) {
    var cookie = all_cookies[i];
    while (cookie.charAt(0) == ' ') cookie = cookie.substring(1, cookie.length);
    if (cookie.indexOf(cookie_fullname) === 0){
        $parameters.CookieValue = cookie.substring(cookie_fullname.length, cookie.length);
    } 
        
}
};
});


        link.rel = $parameters.RelName;
        link.href = $parameters.URL;
        //Add to the top of the head
        document.head.insertBefore(link, document.head.firstChild);
        return;
    } 
    
    //if meta tag already in DOM, update content
    linkElement.href = $parameters.URL;   
})();
};
});


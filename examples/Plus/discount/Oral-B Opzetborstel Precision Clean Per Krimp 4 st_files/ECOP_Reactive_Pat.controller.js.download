return function ($parameters, $actions, $roles, $public) {

function manipulateURL_Regex(url,regexString) {
    var url_search = url;
    var regex = new RegExp(regexString,"g");
    var regexMatch = regex.exec(url_search);

    if(regexMatch)
        url_search = url_search.replace(regexMatch[0],"");

    if(url_search.charAt(0) == "&" || url_search.charAt(0) == "?")

define("ECOP_Reactive_Pat.controller$PageNumber_GetFromURL.GetPageNumberJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const regexString = $parameters.PageParamenterName+'=([0-9]+)?';
const regex = new RegExp(regexString,"g");
const regexMatch = regex.exec(window.location.search);

if(regexMatch === null){
    //if page is not provided we set it as page 1
    $parameters.PageNumber = 1;
    $parameters.IsPageInUrl = false;
    return;
} 

//extrapolate the page
$parameters.PageNumber = parseInt(regexMatch[0].split('=')[1]);
$parameters.IsPageInUrl = true;
};
});


/*  ------------------------------------------------ */
/*  ---------------- AnimatedLabel ------------------*/
/*  ------------------------------------------------ */
function AnimatedLabel() {
    
    var onFocus = function (event) {
        var animatedLabelEl;
        animatedLabelEl = OutSystems.OSUI.Utils.GetClosest(event.target, '.animated-label');
        if(animatedLabelEl){
            animatedLabelEl.classList.add('active');  
        } 
    };
    
    var onBlur = function (event) {
        var animatedLabelEl;
        animatedLabelEl = OutSystems.OSUI.Utils.GetClosest(event.target, '.animated-label');
        if (this.value.length === 0 && animatedLabelEl) {
            animatedLabelEl.classList.remove('active');
        }
    };
    
    var addEventListeners = function(input) {    
        
        if (input !== null) {
            input.addEventListener("focus", onFocus, true);
            input.addEventListener("blur", onBlur, true);
            input.addEventListener('animationstart', onAnimationStart, false);
            input.addEventListener("change", onAnimationStart, true);
        }
    };
    
    var updateLabel = function (input) {
        var animatedLabelEl;
        animatedLabelEl = OutSystems.OSUI.Utils.GetClosest(input, '.animated-label');

        if (input!== null && animatedLabelEl) {
            if (input.value === '' && input !== document.activeElement ) {
                animatedLabelEl.classList.remove('active');
                if(event && event.animationName === "onAutoFillStart") {
                    animatedLabelEl.classList.add('active');
                }
            } else {
               animatedLabelEl.classList.add('active'); 
            }            
        }
    };
    
    var onAnimationStart = function() {
        updateLabel(this);
    };

    return {
      
    //wrapperId from animated label wrapper
    init: function(wrapperId) {
        
        var input = document.getElementById(wrapperId);
        input = input.querySelector('input');
        var animatedLabelEl = OutSystems.OSUI.Utils.GetClosest(input, '.animated-label');
        
        if(input !== null && animatedLabelEl) {
            addEventListeners(input);
            if(input.value !== ""){
                animatedLabelEl.classList.add('active');
            }

        }
    },
    update: function(wrapperId) {
        
        var input = document.getElementById(wrapperId);
        input = input.querySelector('input');

        updateLabel(input);
        
    },
    destroy: (wrapperId) => {
        var input = document.getElementById(wrapperId);
        if(input !== null) {
            input = input.querySelector('input');
        
            if (input !== null) {
                input.removeEventListener("focus", onFocus, true);
                input.removeEventListener("blur", onBlur, true);
                input.removeEventListener('animationstart', onAnimationStart, false);
                input.removeEventListener("change", onAnimationStart, true);
            }
        }
    }
  };

}



/*  ------------------------------------------------ */
/*  ---------------- InViewport    ------------------*/
/*  ------------------------------------------------ */

function isInViewport(element) {
    const rect = element.getBoundingClientRect();
    return (
        rect.top >= 0 &&
        rect.left >= 0 &&
        rect.bottom <= (window.innerHeight || document.documentElement.clientHeight) &&
        rect.right <= (window.innerWidth || document.documentElement.clientWidth)
    );
}

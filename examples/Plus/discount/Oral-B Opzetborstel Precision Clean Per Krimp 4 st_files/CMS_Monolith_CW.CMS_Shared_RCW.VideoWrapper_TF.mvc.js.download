return function ($parameters, $actions, $roles, $public) {
 const p = /^(?:https?:\/\/)?(?:m\.|www\.)?(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))((\w|-){11})(?:\S+)?$/;
if($parameters.URL.match(p)){
    $parameters.IsYoutubeVideo = true;
 
    if($parameters.URL.toLowerCase().includes('embed'))
    {
        $parameters.YoutubeEmbedURL = $parameters.URL;
    }
    else{
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
        const match = $parameters.URL.match(regExp);

        $parameters.YoutubeEmbedURL = (match && match[2].length === 11) ? 'https://www.youtube.com/embed/' + match[2] : $parameters.URL;
    }
}
    
};

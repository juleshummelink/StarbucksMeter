define("ECOP_Reactive_Pat.PL_PopperJS.Popper.mvc$controller.CloseAll.CloseAllPoppersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var poperHTML = document.getElementById($parameters.PopperId); 
var pops = document.querySelectorAll('[data-popper-item="opened"]');
for(var i=0; i<pops.length; i++){
    if(poperHTML && pops[i] !== poperHTML && pops.length > 1){
       pops[i].click(); 
    }
}

};
});
define("ECOP_Reactive_Pat.PL_PopperJS.Popper.mvc$controller.CreatePopper.init_PopperJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

var popcorn = document.getElementById($parameters.ItemId);
var content = document.getElementById($parameters.ContentId);
var arrow = document.getElementById($parameters.ArrowId);


$parameters.popperObj = Popper.createPopper(popcorn, content, {
    placement: $parameters.PopperPositionId, //preferred placement of popper
    modifiers: [
      {
        name: "offset", //offsets popper from the reference/button
        options: {
          offset: [0, 8]
        }
      }
    ]
});

// Update its position
$parameters.popperObj.update();
 

 
};
});
define("ECOP_Reactive_Pat.PL_PopperJS.Popper.mvc$controller.OnReady.JavaScript1JS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var showEvents = ['mouseenter', 'focus'];
var hideEvents = ['mouseleave', 'blur'];
var button = document.getElementById($parameters.PopperElemId);

showEvents.forEach(function(event){
  button.addEventListener(event, $actions.TogglePopper_Open);
});

hideEvents.forEach(function(event) {
  button.addEventListener(event, $actions.TogglePopper_Close);
});
};
});
define("ECOP_Reactive_Pat.PL_PopperJS.Popper.mvc$controller.OnReady.JavaScript2JS", [], function () {
return function ($parameters, $actions, $roles, $public) {

var button = document.getElementById($parameters.PopperElemId);


button.addEventListener("click", $actions.TogglePopper);


};
});
define("ECOP_Reactive_Pat.PL_PopperJS.Popper.mvc$controller.DestroyPopper.destroyJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if ($parameters.popperObj) {
    $parameters.popperObj.destroy();
    $parameters.popperObj = null;
}

$parameters.popperObj_Out = $parameters.popperObj;
};
});


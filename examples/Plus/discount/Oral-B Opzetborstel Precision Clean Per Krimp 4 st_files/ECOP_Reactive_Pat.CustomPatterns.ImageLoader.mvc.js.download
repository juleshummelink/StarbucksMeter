define("ECOP_Reactive_Pat.CustomPatterns.ImageLoader.mvc$controller.Screen_ImageDidMount.OnErrorLoadEventListenerJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
$parameters.ImgObject = document.getElementById($parameters.ImgId);

$parameters.ImgObject.onload = null;
$parameters.ImgObject.onerror = null;

if($parameters.IsAddPerfMark){
    const onLoadFn = ()=>{
        $parameters.ImgObject.classList.remove('hide-img');
        $parameters.ImgObject.previousSibling.style.display='none';
        if(performance.getEntriesByName('hero-image').length<4) performance.mark('hero-image');
    }
    $parameters.ImgObject.addEventListener('load', onLoadFn, {once: true})
}
else
{
    const onLoadFn = ()=>{
        $parameters.ImgObject.classList.remove('hide-img');
        $parameters.ImgObject.previousSibling.style.display='none';
    }    
    $parameters.ImgObject.addEventListener('load', onLoadFn, {once: true});
}

};
});


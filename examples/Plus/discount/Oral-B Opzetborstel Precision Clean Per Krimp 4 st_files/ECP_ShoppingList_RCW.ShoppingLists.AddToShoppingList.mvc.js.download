return function ($parameters, $actions, $roles, $public) {
var list = document.getElementById($parameters.ListId);
var totalHeight = 0;

for(var i = 0; i <= $parameters.MaxVisibleItems - 1; i++) {
    var itemStyle = getComputedStyle(list.querySelectorAll('div.margin-bottom-s')[i]);
    totalHeight += parseInt(itemStyle.height) + parseInt(itemStyle.marginBottom);
}

list.style.maxHeight = totalHeight + 'px';
};
});


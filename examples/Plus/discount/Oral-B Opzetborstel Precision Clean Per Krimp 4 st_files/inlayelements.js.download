var clickedalready = 0;
var timer2 = "";

function clickevent() {

	setTimeout(function () {		
		myFrame = document.getElementById("chatInlayccl");
		myFrame1 = document.getElementById("chatInlay");

		var timer = "";
		var chatEndMsgTimer = "";
		contentElement = myFrame1.contentDocument || myFrame1.contentWindow.document;
		secondContentElement = myFrame.contentDocument || myFrame.contentWindow.document;
		//Update typing message
		var targetNodes = myFrame1.contentWindow.document.querySelectorAll(".agent-activity");
		var MutationObserver = window.MutationObserver || window.WebKitMutationObserver;
		var myObserver = new MutationObserver(mutationHandler);
		var obsConfig = { childList: true, characterData: true, subtree: true };

		//--- Add a target node to the observer. Can only add one node at a time.
		myObserver.observe(targetNodes[0], obsConfig);

		function mutationHandler(mutationRecords) {		
			mutationRecords.forEach(function (mutation) {
				if (mutation.type == "characterData") {
					
					var el = contentElement.querySelectorAll(".agent-activity");
					for (var i = 0; i < el.length; i++) {
						var typingmessage = el[i].innerHTML;
						if (typingmessage != "") {
							var FirstName = typingmessage.substr(0, typingmessage.indexOf(' '));
							var message = typingmessage.substr(typingmessage.indexOf('is aan het typen...') - 1);
							el[i].text(FirstName + message);
						}
					}
				}

			});
		}
		var el = contentElement.querySelectorAll(".screen-minimized");
		for (var i = 0; i < el.length; i++) {
			el[i].addEventListener('click', handleClick);
		}

		var contentframe = myFrame.contentDocument || myFrame.contentWindow.document;

		var element = contentframe.querySelectorAll(".oit-inlay-body");
		for (var j = 0; j < element.length; j++) {
			element[j].addEventListener('click', removechatinlay);
		}
		function removechatinlay(){
			document.getElementById("chatInlayccl").remove();
		}
		function handleClick() {
			hideSurvey();
			if (timer == "")
				timer = setInterval(setCategorySelector, 1000);
		}

		if (timer == "")
			timer = setInterval(setCategorySelector, 1000);
		
		function setCategorySelector() {
			var el = contentElement.querySelectorAll(".screen-transcript .oit-chat-bubble-message");
			for (var i = 0; i < el.length; i++) {
				if (el[i].innerHTML.includes("Dag, mijn naam is") && el[i].innerHTML.includes("Hoe kan ik u van dienst zijn?")) {
					var str = el[i].innerHTML;
					var agentName = str.substr(18, str.indexOf('. Hoe kan ik u van dienst zijn?') - 18);
					var agentFirstName = agentName.substr(0, agentName.indexOf(' '));
					if (agentFirstName != "") {
						str = str.replace(agentName, agentFirstName);
					}
					str = str.replace(". Hoe kan ik u van dienst zijn?", ", waar kan ik je mee helpen?");
					str = str.replace("Dag, mijn naam is", "Hoi, welkom bij PLUS. Ik ben");
					el[i].innerHTML = str;
				}
			}
			var el1 = contentElement.querySelectorAll(".oit-chat-bubble-container.oit-chat-bubble-warning > .oit-chat-bubble > .oit-chat-bubble-standard > .oit-chat-bubble-content");
			for (var i = 0; i < el1.length; i++) {
				if (el1[i].innerText.includes("heeft de chat verlaten.")) {
					var str = el1[i].innerText.trim();
					var agentName = str.substr(0, str.indexOf(' heeft de chat verlaten.'));
					var agentFirstName = agentName.substr(0, agentName.indexOf(' '));
					if (agentFirstName != "") {
						str = str.replace(agentName, agentFirstName);
						el1[i].innerText = str;
					}
				}

				if (el1[i].innerText.includes(" heeft de verbinding verbroken.")) {
					var str1 = el1[i].innerText.trim();
					var agentName1 = str1.substr(0, str1.indexOf(' heeft de verbinding verbroken.'));
					var agentFirstName1 = agentName1.substr(0, agentName1.indexOf(' '));
					if (agentFirstName1 != "") {
						str1 = str1.replace(agentName1, agentFirstName1);
						el1[i].innerText = str1;
						clearInterval(timer);
					}
				}
			}
			
			var el2 = contentElement.querySelectorAll(".oit-chat-bubble-container.oit-chat-bubble-warning > .oit-chat-bubble > .oit-chat-bubble-standard > .oit-chat-bubble-content > .oit-chat-bubble-message"); 
			for (var i = 0; i < el2.length; i++) {
					if (el2[i].innerText.includes(" heeft de verbinding verbroken.")) {
						var str1 = el2[i].innerText.trim();
						var agentName1 = str1.substr(0, str1.indexOf(' heeft de verbinding verbroken.'));
						var agentFirstName1 = agentName1.substr(0, agentName1.indexOf(' '));
						if (agentFirstName1 != "") {
							str1 = str1.replace(agentName1, agentFirstName1);
							el2[i].innerText = str1;
							clearInterval(timer);
						}
					}

			}

			
			if (contentElement.querySelectorAll(".oit-chat-bubble-message").length == 0) {
				return;
			}
			if (contentElement.querySelectorAll(".categorymenuoption").length == 1) {
				timer = "";
				return;
			}
			if (contentElement.querySelectorAll(".oit-chat-bubble-message").length > 1) {
				timer = "";
				return;
			}


		}
		
		
		if (chatEndMsgTimer == "")
			chatEndMsgTimer = setInterval(changeChatEndMessage, 1000);
		
		function changeChatEndMessage(){
			var el = contentElement.querySelectorAll(".screen-transcript .oit-chat-bubble-message");
			for (var i = 0; i < el.length; i++) {
				if (el[i].innerText.includes("U kunt dit venster sluiten.")) {
					var str = el[i].innerText.trim();
					var stringNeedToBeChanged = "U kunt dit venster sluiten.";
					var stringBeforeChange = str.substr(0, str.indexOf(stringNeedToBeChanged));
					var stringForChange = "Je kunt dit venster sluiten.";
					el[i].innerText = stringBeforeChange + stringForChange;
					clearInterval(chatEndMsgTimer);
				}
			}
		}

		function hideSurvey()
		{
			if (window.parent.document.getElementById("chatInlay")!=null && window.parent.document.getElementById("chatInlay").contentDocument!=null)
			{
				if (window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("oit-inlay-status")!=null &&
					window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("oit-inlay-status")[1]!=null)
				{
					window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("oit-inlay-status")[1].style.display = "block";
				}
				if (window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("transcript-datetime")!=null &&
					window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("transcript-datetime")[0]!=null)
				{
					window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("transcript-datetime")[0].style.display = "block";
				}
				if (window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("transcript-message-container")!=null && 
					window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("transcript-message-container")[0]!=null)
				{
					window.parent.document.getElementById("chatInlay").contentDocument.getElementsByClassName("transcript-message-container")[0].style.display = "block";
				}
			}
		}
		
		myFrame1.contentWindow.document.getElementById("closeChatButton").onclick = function (e) {	
			setTimeout(function () {
				var ojDialog = window.parent.document.getElementById("chatInlay").contentDocument.getElementsByTagName("oj-dialog");
				if (ojDialog != null) {//sluiten or verbinding verbreken														
					ojDialog[0].getElementsByTagName("oj-button")[0].onclick = function () {
						
						if ( this.innerText.includes("Sluiten")
						)
						{
							//hiding survey
							hideSurvey();	
							
						}
					}
				}

				if (window.parent.document.getElementById("chatInlay").contentDocument.getElementById("ui-id-10") != null) {
					window.parent.document.getElementById("chatInlay").contentDocument.getElementById("ui-id-10").onclick = function () {
						hideSurvey();					
					};
				}
			}, 0);
		};
	}, 0);
}


function start() {
	var frame = document.getElementById('chatInlay');
	var c = frame.contentDocument || frame.contentWindow.document;
	var inner_wp = c.querySelectorAll('.oit-inlay-header-actions-close svg');
	console.log(inner_wp);
	inner_wp[inner_wp.length - 1].setAttribute("id", "closeChatButton");
	const elementToObserve = window.parent.document.getElementById("chatInlay");
	const observer = new MutationObserver(changeHeight);
	observer.observe(elementToObserve, {subtree: false, childList: false, attributes: true, attributeFilter: ['data-oit-mode']});
}

async function checkCategoryIssue(){	
	await getChatIssue();
	var frame = document.getElementById('chatInlay');
	var c = frame.contentDocument || frame.contentWindow.document;
	var el = c.getElementById("title-link");
	console.log(el);
	if(el)
		el.removeEventListener("click", function(){});
	if(el.parentElement.parentElement.style.display != "none"){
		if(listenerCount == 0){
			el.addEventListener("click", function(){
				checkCategoryIssue();
				listenerCount++;
			});
		}
	}
	const elementToObserve = c.getElementById("custom-field-chat_category|input");
	const observer = new MutationObserver(Callback);
	observer.observe(elementToObserve, {subtree: false, childList: false, attributes: true, attributeFilter: ['aria-expanded']});
}

function Callback (mutations) {
	var frame = document.getElementById('chatInlay');
	var c = frame.contentDocument || frame.contentWindow.document;
	for (let mutation of mutations) {
		if (mutation.type === 'attributes') {
			if(mutation.attributeName === 'aria-expanded'){
				var expanded = contentElement.getElementById("custom-field-chat_category|input").getAttribute('aria-expanded');
				if(expanded == 'false'){
					var warning = c.getElementById("alert");
					if(warning)
						warning.remove();
					var selectedCategory = contentElement.getElementById("custom-field-chat_category|input").value;
					if(selectedCategory){
						var issueCategories = issues;
						console.log(issueCategories);
						if(issueCategories){
							//issueCategories = issueCategories.split(',');
							console.log(issueCategories);
							if(issueCategories.includes(selectedCategory)){
								var info;
								if(alertMessages[selectedCategory]) info = alertMessages[selectedCategory];
								var div = document.createElement("div");
								div.setAttribute("id", "alert");
								div.innerHTML += '<span class="closebtn" onclick="this.parentElement.style.display=\'none\';">&times;</span>'; 
								div.innerHTML += info;
								c.getElementById("launch-form-tracker").prepend(div);
							}
						}
					}
					/*if(selectedCategory == "Shoppingcart"){
						var info = sessionStorage.getItem(selectedCategory);
						var div = document.createElement("div");						
						div.setAttribute("id", "alert");
						
						c.getElementById("launch-form-tracker").prepend(div);
					}*/
				}
			}
		}	
	}
}


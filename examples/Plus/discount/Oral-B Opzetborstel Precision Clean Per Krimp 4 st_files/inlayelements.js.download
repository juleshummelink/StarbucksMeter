var issues;
let listenerCount = 0;
var alertMessages = {
	"Online bestellen": null,
	"Winkelinformatie" : null,
	"Aanbiedingen" : null,
	"Assortiment" : null,
	"Anders" : null
};

window.addEventListener("message", receiveMessage, false);
function receiveMessage(event)
{
  if (event.origin !== "https://plus-consumentenservice.custhelp.com" && event.origin !== "https://www.plus.nl")
     return;
  if (event.data == "scrollTop"){
	window.parent.scrollTo(0,0);
  }
}

async function getChatIssue(){
	var url = 'https://plus-consumentenservice.custhelp.com/cgi-bin/plus_consumentenservice.cfg/php/custom/check_category_issue.php';
	var xhr = new XMLHttpRequest();
	if (!('withCredentials' in xhr)) xhr = new XDomainRequest(); // fix IE8/9
	xhr.open('POST', url);
	xhr.onreadystatechange = function () {
		if (xhr.readyState === 4) {
			var response = JSON.parse(xhr.response);
			if(response.ChatIssueCategory) {
				var issueCategories = response.ChatIssueCategory;
				issues = issueCategories.split(',');
			}
			console.log(response);
			alertMessages['Online bestellen'] = response.Online_bestellen;
			alertMessages['Winkelinformatie'] = response.Winkelinformatie;
			alertMessages['Aanbiedingen'] = response.Aanbiedingen;
			alertMessages['Assortiment'] = response.Assortiment;
			alertMessages['Anders'] = response.Anders;
		}
	};
	xhr.send();
}


var inlayccl = document.createElement('inlay-oracle-chat-ccl');
inlayccl.setAttribute('id', 'chatInlayccl');
inlayccl.setAttribute('class', 'inlay');
inlayccl.setAttribute('link-action', 'fireEvent');
inlayccl.setAttribute('inlay-mode', 'BOTTOM_RIGHT');
inlayccl.setAttribute('agent-check-enabled', 'true');
inlayccl.setAttribute('agent-minimum', '1');
inlayccl.setAttribute('agent-polling-enabled', 'true');
inlayccl.setAttribute('agent-hide-if-unavailable', 'true');
inlayccl.setAttribute('site-url', 'plus-consumentenservice.widget.custhelp.com');

var inlayembed = document.createElement('inlay-oracle-chat-embedded');
inlayembed.setAttribute('id', 'chatInlay');
inlayembed.setAttribute('class', 'inlay');
inlayembed.setAttribute('anonymous-chat-enabled', 'false');
inlayembed.setAttribute('chat-bubble-name-enabled', 'false');
inlayembed.setAttribute('launch-form-fields', '["FIRST_NAME","LAST_NAME","EMAIL*","c$chat_category*", {"name": "c$chat_launch_url", "hidden": true, "required": false, "value": "'+window.parent.location+'"}]');
inlayembed.setAttribute('inlay-hidden', 'true');
inlayembed.setAttribute('file-upload-enabled', 'true');
inlayembed.setAttribute('post-chat-print-transcript-enabled', 'false');
inlayembed.setAttribute('off-the-record-patterns', '[]');

inlayembed.setAttribute('log-level', 'none');
inlayembed.setAttribute('site-url', 'plus-consumentenservice.widget.custhelp.com');

document.body.appendChild(inlayccl);
document.body.appendChild(inlayembed);


function changeHeight(mutations){
	 mutations.forEach((mutation) => {
		console.log(mutation);
		switch (mutation.type) {
		  case "attributes":
			switch (mutation.target.dataset.oitMode) {
			  case "overlay-br-min":
				window.parent.document.getElementById("chatInlay").setAttribute("style", "height: 90px !important; width:78px");
				break;
			  case "overlay-br-max":
				window.parent.document.getElementById("initial-chatInlay").innerHTML = '#chatInlay{height: 90px;}';
				window.parent.document.getElementById("initial-chatInlayCcl").innerHTML = '#chatInlayCcl{height: 90px; border:0;}';
				var invalidEmail = contentElement.getElementById("launch-form-email|input").getAttribute('aria-invalid');
				var invalidCategory = contentElement.getElementById("custom-field-chat_category|input").getAttribute('aria-invalid');
				if(invalidEmail == "true" && invalidCategory == "true"){
					window.parent.document.getElementById("chatInlay").setAttribute("style", "height: 430px !important;");
				} else if (invalidEmail == "true" || invalidCategory == "true"){
					window.parent.document.getElementById("chatInlay").setAttribute("style", "height: 425px !important;");
				} else {
					window.parent.document.getElementById("chatInlay").setAttribute("style", "height: 363px !important;");
				}				
				break;
			  case "fullscreen":
				window.parent.document.getElementById("chatInlay").setAttribute("style", "height: 100% !important; width: 100% !important");
			}
			break;
		}
	});
}

var numberofmessagesWhenVisible = 0;
var numberofmessagesWhenNotVisible = 0;
var myFrame1;
var contentElement;
var secondContentElement;
var title = document.title;


var vis = (function () {
	var stateKey, eventKey, keys = {
		hidden: "visibilitychange",
		webkitHidden: "webkitvisibilitychange",
		mozHidden: "mozvisibilitychange",
		msHidden: "msvisibilitychange"
	};
	for (stateKey in keys) {
		if (stateKey in document) {
			eventKey = keys[stateKey];
			break;
		}
	}
	return function (c) {
		if (c) document.addEventListener(eventKey, c);
		return !document[stateKey];
	}
})();

timeoutMain();

function timeoutMain() {
	setTimeout(function () {
		if (document.getElementById("chatInlay") != null && document.getElementById("chatInlay").contentDocument != null && document.getElementById("chatInlay").contentDocument.getElementsByClassName("oit-inlay-header-actions-close").length > 0) {			
			customizeChatInlay();
			customizeChatInlayccl();
			clickevent();
			start();
		} else timeoutMain();
	}, 0);
}


scription": "When true, check for chat agent availability. Otherwise, the link will always display regardless of availability or hours of operation.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "type": "boolean",\n      "value": true\n    },\n    "agentHideIfUnavailable": {\n      "description": "When true, hide the inlay when the conditions for chat availability are not met. Otherwise, it is always visible.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "type": "boolean",\n      "value": true\n    },\n    "agentMinimum": {\n      "description": "Minimum number of available agent sessions in order for the link to be actionable. This attribute overrides agent-wait-threshold and is disabled when set to 0.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "format": "int32",\n      "minimum": 0,\n      "type": "number",\n      "value": 0\n    },\n    "agentPollingEnabled": {\n      "description": "When true, poll for availability information after the page has loaded. The inlay will poll every 12 seconds for the first 5 minutes, once per minute for the next 55 minutes and stop after one hour.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC"\n        }\n      },\n      "type": "boolean",\n      "value": true\n    },\n    "agentWaitThreshold": {\n      "description": "Maximum wait time in queue in seconds. This attribute is overriden by agent-minimum and is disabled when set to 0.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "format": "int32",\n      "minimum": 0,\n      "type": "number",\n      "units": "seconds",\n      "value": 120\n    },\n    "categoryId": {\n      "description": "The ID of a single category to use.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC",\n          "siteTypes": {\n            "osvc": "18D"\n          }\n        }\n      },\n      "type": "string"\n    },\n    "chatLaunchUrl": {\n      "description": "Fully qualified URL to a page that launches a chat session.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC",\n          "siteTypes": {\n            "osvc": "18D"\n          }\n        }\n      },\n      "type": "string"\n    },\n    "eeData": {\n      "description": "INTERNAL USE ONLY. Engagement Engine data to pass to the chat server.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC",\n          "siteTypes": {\n            "osvc": "18D"\n          },\n          "visibility": "INTERNAL"\n        }\n      },\n      "type": "Object<{ee_id: string, ee_s_id: string, es_id: string, referrerUrl: string, v_id: string}>"\n    },\n    "inlayMode": {\n      "description": "Display mode for the inlay.",\n      "enumValues": [\n        "INLINE",\n        "BOTTOM_LEFT",\n        "BOTTOM_RIGHT"\n      ],\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC"\n        }\n      },\n      "type": "string",\n      "value": "INLINE"\n    },\n    "inlayWidth": {\n      "description": "CSS width of the inlay, including units. For example \\"80px\\". Otherwise, the default width varies according to other attributes used.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC"\n        }\n      },\n      "type": "string"\n    },\n    "linkAction": {\n      "description": "Action performed when the user clicks the link.",\n      "enumValues": [\n        "chatLaunch",\n        "fireEvent"\n      ],\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC",\n          "siteTypes": {\n            "osvc": "18D"\n          }\n        }\n      },\n      "type": "string",\n      "value": "fireEvent"\n    },\n    "linkStyle": {\n      "description": "Style of link to be shown.",\n      "enumValues": [\n        "IconOnly",\n        "TextOnly",\n        "Both"\n      ],\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC"\n        }\n      },\n      "required": true,\n      "type": "string",\n      "value": "Both"\n    },\n    "logLevel": {\n      "description": "Log level",\n      "enumValues": [\n        "none",\n        "error",\n        "warn",\n        "info",\n        "log"\n      ],\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC",\n          "visibility": "INTERNAL"\n        }\n      },\n      "type": "string",\n      "value": "error"\n    },\n    "messageEnabled": {\n      "description": "When true, show detailed information on agent availability.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "type": "boolean",\n      "value": false\n    },\n    "pollingMaxQueueSize": {\n      "description": "Maximum number of end users that can be added to a queue.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "format": "int32",\n      "minimum": 1,\n      "type": "number"\n    },\n    "popupEnabled": {\n      "description": "When true, display the page defined by the attribute chat-launch-url in a new window. Otherwise, it will be displayed in the current window.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "type": "boolean",\n      "value": true\n    },\n    "popupHeight": {\n      "description": "Chat window height in pixels if the attribute popup-enabled is set to true.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "format": "int32",\n      "minimum": 0,\n      "type": "number",\n      "units": "pixels",\n      "value": 680\n    },\n    "popupWidth": {\n      "description": "Chat window width in pixels if the attribute popup-enabled is set to true.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC"\n        }\n      },\n      "format": "int32",\n      "minimum": 0,\n      "type": "number",\n      "units": "pixels",\n      "value": 700\n    },\n    "productId": {\n      "description": "The ID of a single product to use.",\n      "extension": {\n        "oit": {\n          "dynamic": "DYNAMIC",\n          "siteTypes": {\n            "osvc": "18D"\n          }\n        }\n      },\n      "type": "string"\n    },\n    "queueId": {\n      "description": "The ID of the queue to route this chat.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC",\n          "siteTypes": {\n            "ec": "21A",\n            "osvc": "18D"\n          }\n        }\n      },\n      "type": "string"\n    },\n    "siteType": {\n      "description": "Interaction type for this inlay.",\n      "enumValues": [\n        "b2b-service",\n        "b2c-service",\n        "ec",\n        "osvc"\n      ],\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC"\n        }\n      },\n      "required": true,\n      "type": "string",\n      "value": "b2c-service"\n    },\n    "siteUrl": {\n      "description": "URL of the site-type endpoint for which configuration details are retrieved.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC"\n        }\n      },\n      "required": true,\n      "type": "string"\n    },\n    "strings": {\n      "description": "INTERNAL USE ONLY. Please use config files to customize strings. Direct use of this attribute is not supported and subject to change.",\n      "extension": {\n        "oit": {\n          "dynamic": "STATIC",\n          "visibility": "INTERNAL"\n        }\n      },\n      "type": "Object<string, string>"\n    }\n  },\n  "type": "composite",\n  "version": "0.0.0"\n}\n'})),define("css!oit-inlay-oracle-chat-ccl/styles",[],(function(){})),define("oit-inlay-oracle-chat-ccl/loader",["ojs/ojcomposite","text!./view.html","./view-model","text!./component.json","css!./styles"],(function(e,t,n,i){e.register("inlay-oracle-chat-ccl",{metadata:JSON.parse(i),view:t,viewMode
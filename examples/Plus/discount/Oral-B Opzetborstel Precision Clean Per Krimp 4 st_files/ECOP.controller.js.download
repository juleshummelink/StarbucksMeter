define("ECOP.controller$ManageFocusState_OnFocusOutEvent.HandleSkippableContent_TabJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const eventObj = $parameters.FocusInEvent;
const isBackward = $parameters.LastKeyWasShiftTab;

// Return to normal focus flow for regular Tab-press when target is not skippable
if (!$actions.Helper_CheckSkippable(eventObj.target).IsSkippable && !isBackward) {
    return;
}

const focusedEl = eventObj.relatedTarget;
if (!focusedEl) return;

//Example: Menubar is skippable (= Target) & FocusedEl = MenuItem (= related target). skippableAncestor is the menubar.
const skippableAncestor = $actions.Helper_GetSkippableAncestor(focusedEl).AncestorElement;

//If focussed related target is not a child of container with data-skippable=true, return to normal focus flow
if (!skippableAncestor) return;

const fromSkippable = $actions.Helper_GetSkippableAncestor(eventObj.target).AncestorElement;

// Early exit: Allow normal navigation within the same skippable container
if (fromSkippable && fromSkippable === skippableAncestor) {
    return;
}

const focusables = $actions.Helper_GetAllFocusableElements().FocusableElements
let currentIndex = focusables.indexOf(focusedEl);
if (currentIndex === -1) return; //Failsafe; Should never happen

let newIndex = isBackward ? currentIndex - 1 : currentIndex + 1;

    while (
        newIndex >= 0 &&
        newIndex < focusables.length &&
        $actions.Helper_GetSkippableAncestor(focusables[newIndex]).AncestorElement
    ) {
        
        newIndex += isBackward ? -1 : 1;
    }

const nextFocusable = focusables[newIndex];
if (nextFocusable) {
    nextFocusable.focus();
}
};
});


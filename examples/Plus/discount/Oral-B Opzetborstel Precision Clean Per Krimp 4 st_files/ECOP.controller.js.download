define("ECOP.controller$OnApplicationReady_Client.SetHeaderLogoImageFromCacheJS", [], function () {
return function ($actions, $roles, $public) {
var head_logo = document.querySelector('img.app-logo');
if(head_logo && head_logo.getAttribute('src') == "" && globalThis && globalThis.cachedStaticImgs) {

    var imgObj = globalThis.cachedStaticImgs.find(item => {
        return item.Slug == "PLUS_ECOP_LOGO_MAIN";
    });
    head_logo.setAttribute('src', imgObj.URL)
}

//Add the pull to refresh behavior on mobile browsers
if(document.body.classList.contains("phone") || document.body.classList.contains("tablet")){
    document.body.classList.add("overflow-auto");
    document.documentElement.classList.add("overflow-auto");
}

};
});

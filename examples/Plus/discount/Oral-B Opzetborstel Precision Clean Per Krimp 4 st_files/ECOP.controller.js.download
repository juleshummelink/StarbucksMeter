define("ECOP.controller$AddEventListeners.MouseClickAndKeyDownEventListenersJS", [], function () {
return function ($actions, $roles, $public) {
const keyPressDown = function(e) {
    try {
        $actions.EventHandler_KeyDown(KeyDownEvent = e, Key = e.key, IsShiftKey = e.shiftKey)
    } catch (error) {
        console.error("Error in EventHandler_KeyDown client action:", error);
    }
};

const mouseDown = function() {
    try {
        $actions.EventHandler_MouseDown()
    } catch (error) {
        console.error("Error in EventHandler_MouseDown client action:", error);
    }
};

document.addEventListener('keydown', keyPressDown);
document.addEventListener('mousedown', mouseDown);
};
});
define("ECOP.controller$AddEventListeners.AddFocusOutEventListenerJS", [], function () {
return function ($actions, $roles, $public) {
const focusOutHandler = function(e) {
    try {
        $actions.EventHandler_FocusOut(FocusOutEvent = e); 
    } catch (error) {
        console.error("Error in EventHandler_FocusOut: ", error);
    }
};

document.addEventListener('focusout', focusOutHandler);
};
});


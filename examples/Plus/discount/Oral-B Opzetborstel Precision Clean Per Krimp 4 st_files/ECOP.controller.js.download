define("ECOP.controller$InitializeScreenErrorsLogging.JSOverwritteFeedbackMessagePrototypeJS", [], function () {
return function ($actions, $roles, $public) {
let fms = require('OutSystems/ClientRuntime/FeedbackMessageService');
let original = require('OutSystems/ClientRuntime/FeedbackMessageService').showFeedbackMessage;

fms.showFeedbackMessage = function(...args) {
    if(args[1] === 3 || args[1] === 2){

        
        setTimeout( ()=>{
            const regExp = /\(([^)]+)\)/;
            const getOS = regExp.exec(navigator.userAgent)[1].split('; ')[1];

            $actions.CreateGlobalLog(32, 'FeedbackMessageTrace', 0, `A user feedback ${args[1] === 3 ? 'error': 'warning'} message was presented to user.`, JSON.stringify({feedbackMessage: args[0], feedbackMessageType: args[1] === 3 ? 'error': 'warning', screen: location.pathname, owguid: localStorage.$OS_Users$ECOP_FE_Core$ClientVars$OWGUID ? localStorage.$OS_Users$ECOP_FE_Core$ClientVars$OWGUID : '', device: {isMobile: navigator.userAgent.includes('iPhone') || navigator.userAgent.includes('Android') ? true : false, browser: navigator.browserSpecs.name + ' ' + navigator.browserSpecs.version, os: getOS, brand: 'N/A', model: 'N/A'}}))

            window.dataLayer.push({
                'event': 'feedback_message',
                'feedback_type': args[1] === 3 ? 'error': 'warning',
                'feedback_content': args[0]
            });
        },0)
    }
        return original.apply(this,args)
}
console.log('Overwrite applied.')
};
});
define("ECOP.controller$InitializeScreenErrorsLogging.JSOverwritteFeedbackMessagePrototypeV2JS", [], function () {
return function ($actions, $roles, $public) {
let fms = require('OutSystems/ClientRuntime/FeedbackMessageService');
let original = require('OutSystems/ClientRuntime/FeedbackMessageService').showFeedbackMessage;

fms.showFeedbackMessage = function(...args) {
    if(args[1] === 3 || args[1] === 2){
        setTimeout( ()=>{
            const regExp = /\(([^)]+)\)/;
            const getOS = regExp.exec(navigator.userAgent);
            const blacklist = new RegExp('/screenservices/')
            console.log(blacklist.exec(args[0]) != null )
            if (blacklist.exec(args[0]) != null )  {
                $public.FeedbackMessage.closeFeedbackMessage();
            }else{
                $actions.CreateGlobalLog(32, 'FeedbackMessageTrace', 0, `A user feedback ${args[1] === 3 ? 'error': 'warning'} message was presented to user.`, JSON.stringify({feedbackMessage: args[0], feedbackMessageType: args[1] === 3 ? 'error': 'warning', screen: location.pathname, owguid: localStorage.$OS_Users$ECOP_FE_Core$ClientVars$OWGUID ? localStorage.$OS_Users$ECOP_FE_Core$ClientVars$OWGUID : '', device: {isMobile: navigator.userAgent.includes('iPhone') || navigator.userAgent.includes('Android') ? true : false, browser: navigator.browserSpecs.name + ' ' + navigator.browserSpecs.version, os: getOS, brand: 'N/A', model: 'N/A'}}))
                window.dataLayer.push({
                    'event': 'feedback_message',
                    'feedback_type': args[1] === 3 ? 'error': 'warning',
                    'feedback_content': args[0]
                });
            }
        },0)
    }
        return original.apply(this,args)
}
};
});


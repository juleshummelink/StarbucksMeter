define("ECOP.controller$SpeedCurveConfigs_Apply.HideNotices_JSJS", [], function () {
return function ($actions, $roles, $public) {
//Checks if the navigation is from a SpeedCurve test. If so, we hide the notices
if (navigator.userAgent.includes('PTST/SpeedCurve')) {
    let el = document.createElement('style');
    el.innerHTML = '.cf-notices{display:none !important;}';
    document.head.appendChild(el);
}
};
});


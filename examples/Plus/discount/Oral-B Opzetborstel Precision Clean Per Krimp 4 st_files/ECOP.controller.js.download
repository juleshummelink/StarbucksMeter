define("ECOP.controller$OnScroll_ManageHeader.HideOrShowOnScrollJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if(document.body.classList.contains("scroll-fix"))
    document.body.classList.remove("scroll-fix");
else if(!$actions.Device_IsPhone().IsPhone){
    var layout = document.querySelector('.layout');
    var topHeaderHeight = getComputedStyle(document.documentElement).getPropertyValue('--header-top-bar-height');
    if(!topHeaderHeight) {
        topHeaderHeight = "32";
    }
    topHeaderHeight = parseInt(topHeaderHeight.trim(), 10);
    
    if($parameters.ScreenObj.scrollTop >= topHeaderHeight && !layout.classList.contains("fixed-header"))
        layout.classList.add("fixed-header");
    
    if($parameters.ScreenObj.scrollTop < topHeaderHeight && layout.classList.contains("fixed-header"))
        layout.classList.remove("fixed-header");
    
    if(!this.oldScroll)
        this.oldScroll = 0;
    
    if(this.oldScroll < $parameters.ScreenObj.scrollTop){
        layout.classList.add("hide-menu");
        $actions.CloseAllSubmenus();
    }
    else
        layout.classList.remove("hide-menu");
    
    this.oldScroll = $parameters.ScreenObj.scrollTop;
}

};
});


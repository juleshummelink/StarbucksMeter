return function ($parameters, $actions, $roles, $public) {
let current = $parameters.Element.parentElement; // Start from parent, not the element itself

$parameters.AncestorElement = null;

while (current && current !== document.body) {
  if ($actions.Helper_CheckSkippable(current).IsSkippable) {
    $parameters.AncestorElement = current;
    break;
  }
  current = current.parentElement;
}

};
});


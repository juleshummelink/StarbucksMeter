return function ($parameters, $actions, $roles, $public) {
const el = $parameters.EventObj.target;   

if(!$actions.Helper_CheckSkippable(el).IsSkippable){
    return
}

const focusables = $actions.Helper_GetAllFocusableElements(ParentContainer = el).FocusableElements

const nextFocusable = focusables.length > 0 ? focusables[0] : null;

if (nextFocusable) {
    $parameters.EventObj.preventDefault(); //Avoids clicking the first element
    nextFocusable.focus();
    $parameters.IsFocusChanged = true
}
};
});

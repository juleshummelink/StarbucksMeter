define("ECOP.controller$AddPrerenderLink.AddSpeculationRuleJS", [], function () {
return function ($actions, $roles, $public) {
if (HTMLScriptElement.supports && HTMLScriptElement.supports('speculationrules') && !document.querySelector('script[type="speculationrules"')) {
  const specScript = document.createElement('script');
  specScript.type = 'speculationrules';
  specRules = {
    "prerender": [
      {
        "source": 'list',
        "urls": ['/aanbiedingen'],
        "target_hint": "_self"
      },
    ],
  };
  specScript.textContent = JSON.stringify(specRules);
  console.log('added speculation rules');
  document.body.append(specScript);
}
};
});


define("ECOP.controller$RemovePreloadHTML.RemovePrerenderHTMLJS", [], function () {
return function ($actions, $roles, $public) {
var fake_el = document.querySelector("#fast_cont");
if(fake_el){
    document.querySelector(".screen-container").scrollTop = fake_el.scrollTop;
    document.body.classList.add("scroll-fix");
    if(fake_el.classList.contains("hide-menu")) 
        document.querySelector(".screen-container .layout").classList.add("hide-menu", "fixed-header");
    setTimeout(function(){
        if(fake_el)
            document.body.removeChild(fake_el);
    }, 200);
}
};
});


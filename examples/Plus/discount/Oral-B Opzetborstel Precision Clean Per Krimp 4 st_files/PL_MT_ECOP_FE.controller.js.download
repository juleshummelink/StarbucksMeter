(function(open) {
    XMLHttpRequest.prototype.open = function(method, url, async, user, pass) {
        this.addEventListener("readystatechange", function() {
            if (!url.includes("ActionStartTransaction") && !url.includes("ActionEndTransaction") && 
            !url.includes("Transaction") && !url.includes("rum/events") && !url.includes("moduleservices") && !url.includes("ElasticRUM"))
            {
                if (this.readyState == 1){
                    $actions.StartTransaction($parameters.ServiceName, $parameters.ServiceVersion, url, "xhr_server");
                } else if (this.readyState == 4){
                    $actions.EndTransaction();
                }
            }
        }, false);

        open.call(this, method, url, async, user, pass);
    };

})(XMLHttpRequest.prototype.open);
};
});


Controller.prototype._getStoreDetails$Action = function (storeIdIn, callContext) {
var model = this.model;
var controller = this.controller;
var idService = this.idService;
controller.ensureControllerAlive("GetStoreDetails");
callContext = controller.callContext(callContext);
var vars = new OS.DataTypes.VariableHolder(new (controller.constructor.getVariableGroupType("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.GetStoreDetails$vars"))());
vars.value.storeIdInLocal = storeIdIn;
var store_GetInfoVar = new OS.DataTypes.VariableHolder();
var listFilter_StoreVar = new OS.DataTypes.VariableHolder();
return OS.Flow.executeAsyncFlow(function () {
// Execute Action: ListFilter_Store
listFilter_StoreVar.value = OS.SystemActions.listFilter(model.variables.searchStoresDataAct.storesOut, function (p) {
return p.store_IdAttr.equals(vars.value.storeIdInLocal);
}, callContext);

// Execute Action: Store_GetInfo
model.flush();
return controller.store_GetInfo$ServerAction(vars.value.storeIdInLocal, callContext).then(function (value) {
store_GetInfoVar.value = value;
}).then(function () {
// Set Store Info
// StoreInfoRec = Store_GetInfo.StoreInfoR
model.variables.storeInfoRecVar = OS.DataConversion.JSConversions.typeConvertRecord(store_GetInfoVar.value.storeInfoROut, new ECP_Store_CWModel.StoreInfoTextIntegerRecord(), function (source, target) {
target.distanceAttr = listFilter_StoreVar.value.filteredListOut.getCurrent(callContext.iterationContext).distanceAttr;
target.externalChannelIdAttr = listFilter_StoreVar.value.filteredListOut.getCurrent(callContext.iterationContext).store_ExternalChannelIdAttr;
target.storeInfoAttr.storeNameAttr = source.storeNameAttr;
target.storeInfoAttr.openingHoursRangeAttr = source.openingHoursRangeAttr;
target.storeInfoAttr.userStoreIdAttr = source.userStoreIdAttr;
target.storeInfoAttr.storeAddressAttr = source.storeAddressAttr;
target.storeInfoAttr.hasDeliveryAttr = source.hasDeliveryAttr;
target.storeInfoAttr.hasDeliveryExpressAttr = source.hasDeliveryExpressAttr;
target.storeInfoAttr.hasPickupAttr = source.hasPickupAttr;
target.storeInfoAttr.hasPickupExpressAttr = source.hasPickupExpressAttr;
target.storeInfoAttr.storeLatAttr = source.storeLatAttr;
target.storeInfoAttr.storeLongAttr = source.storeLongAttr;
return target;
});
// Execute Action: Toggle_StoreDetails
controller._toggle_StoreDetails$Action(true, callContext);
});
});
};

var markers = OutSystems.Maps.MapAPI.MapManager.GetActiveMap().markers;
var bounds = new google.maps.LatLngBounds();
for (var i = 0; i < markers.length; i++) {
 bounds.extend(markers[i]._provider.position);
}

OutSystems.Maps.MapAPI.MapManager.GetActiveMap()._provider.fitBounds(bounds);
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.RepaintMapClusters.RepaintClustersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

if($parameters.MapObj){
    $parameters.MapObj.features.markerClusterer.markerClusterer.repaint();
}

};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.FitMapToStore.FitToStoreJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var bounds = new google.maps.LatLngBounds();
var myLatLng = new google.maps.LatLng($parameters.StoreLat, $parameters.StoreLong);
bounds.extend(myLatLng);

$parameters.MapObj.provider.fitBounds(bounds);
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.Handler_Map_Initialized.GetMapObjJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
try{
    $parameters.MapObj = OutSystems.Maps.MapAPI.MapManager.GetMapById($parameters.MapId);
}
catch(e){
    $parameters.IsValidMap = false;
}

//Geocoder to get coordinates from address
$parameters.GeoCoderObj = new google.maps.Geocoder();
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.Handler_Map_Initialized.ComputeDistances_AsyncJS", [], function () {
return function ($actions, $roles, $public) {
setTimeout($actions.ComputeDistances, 10);
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.Handler_Map_Initialized.RemovePOIsJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var hide_POI_style = {
  hidePOI: [
    {
      featureType: 'poi.business',
      stylers: [{ visibility: 'off' }],
    }
  ]
};
$parameters.MapObj.provider.setOptions({ styles: hide_POI_style.hidePOI });
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.Set_Map_SelectedStore.RemoveFromClusteringJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

//Add previous to clustering
if($parameters.marker && $parameters.marker.provider){
    $parameters.marker._setIcon("/ECP_Store_CW/img/ECP_Store_CW.plus_store_mapmarker_svg.svg");
    $parameters.MapObj.features.markerClusterer._markerClusterer.addMarker($parameters.marker.provider, false);
}

var myMarker = $parameters.MapObj.markers.filter(function (m) {
        return m._config.location === $parameters.Location;
    }).map(function (m) {
        return m;
    })[0];
    
//Remove the new selected marker from clustering
if(myMarker) {
    $parameters.MapObj.features.markerClusterer._markerClusterer.removeMarker(myMarker.provider, false);
    myMarker._setIcon("/ECP_Store_CW/img/ECP_Store_CW.selected_store_mapmarker_svg.svg");
    myMarker.provider.setMap($parameters.MapObj.provider);
    $parameters.marker_out = myMarker;
}


 
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.ValidateZipcode.IsZipcodeJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if($parameters.PostalCode.match(/^[1-9][0-9]{3} ?(?!sa|sd|ss)[a-z]{2}?$/i)) {
    $parameters.IsValid = true;
}else {
    $parameters.IsValid = false;
}


};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.OnKeyUp_Input.EnterKeyPressedJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if(event.keyCode==13){
    var inputElem = document.getElementById($parameters.InputId);
    if(inputElem)
        inputElem.blur();
        
    $actions.OnClick_SearchStore();

}
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_Deprecated.mvc$controller.SetZoom_NL.ZoomToNLJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var myLatLng = new google.maps.LatLng($parameters.Lat, $parameters.Long);
$parameters.MapObj.provider.setCenter(myLatLng);
$parameters.MapObj.provider.setZoom(7);


};
});


define("ECOP.AA_Common.Menu.mvc$controller.OnReady_Async.CreateMutationObserverJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var options = {
  attributes: true
};


$parameters.SubmenuObserverObj = new MutationObserver(callback);

document.querySelectorAll('.osui-submenu').forEach(function(elem){
    $parameters.SubmenuObserverObj.observe(elem, options);
});


function callback(mutationList, observer) {
    requestAnimationFrame(() => {
        mutationList.forEach(function(mutation) {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                $actions.CheckSubmenuOpen_Phone();

                 // If the submenu is opened, set focus to the first item
                if (mutation.target.classList.contains('osui-submenu--is-open')) {
                    $actions.OnChangeSubMenu_SetFocusOnFirstMenuLink()
                }
            }
        });
    });
}

};
});
define("ECOP.AA_Common.Menu.mvc$controller.OnReady_Async.AddEventListener_SubMenuFocusOutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {


$parameters.menuFocusOutHandler = function(event) {
    if (!$actions.LastKeyPressDocVar_Get().Key) return;
    const submenuItem = event.target.closest('.osui-submenu--is-open .osui-submenu__items [role="menuitem"]');

    if (submenuItem) {
        const relatedTarget = event.relatedTarget;

        // Find the container of the OSUI submenu widget
        const subMenuWidget = submenuItem.closest('[data-block="Navigation.Submenu"]');
        
        if (!relatedTarget || !subMenuWidget.contains(relatedTarget)) {
            $actions.CloseSubmenu(subMenuWidget.id);
        }
    }
};


const menu = document.querySelector('.app-menu-content'); 
menu.addEventListener('focusout', $parameters.menuFocusOutHandler);
};
});
define("ECOP.AA_Common.Menu.mvc$controller.OnParametersChanged.IsMenuOpenJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var layout = document.querySelector('.layout');
var menu = document.querySelector('.app-menu-content');

if(layout && menu)
    $parameters.IsOpen = layout.classList.contains('menu-visible');

};
});
define("ECOP.AA_Common.Menu.mvc$controller.OnChangeSubMenu_SetFocusOnFirstMenuLink.SetFocusJS", [], function () {
return function ($actions, $roles, $public) {
const submenu = document.querySelector('.osui-submenu--is-open');

if (submenu) {
    const firstMenuItem = submenu.querySelector('[role="menuitem"]');

    if (firstMenuItem) {
        firstMenuItem.focus();
    }
}
};
});


define("ECP_Composition_CW.controller$ValidatePromotionCartItem_Optimization", ["exports", "OutSystems/ClientRuntime/Main", "ECP_Composition_CW.model", "ECP_Composition_CW.controller", "ECP_Composition_CW.model$TextTextIntegerRecordList", "ECP_Composition_CW.model$OfferList", "ECP_Composition_CW.model$ProductPromotionBannerCategoryRecord", "ECP_Composition_CW.model$ProductPromotionDetailsList"], function (exports, OutSystems, ECP_Composition_CWModel, ECP_Composition_CWController) {
var OS = OutSystems.Internal;
ECP_Composition_CWController.default.validatePromotionCartItem_Optimization$Action = function (itemExistsInCartIn, promotionIn, callContext) {
callContext = controller.callContext(callContext);
var vars = new OS.DataTypes.VariableHolder(new (controller.constructor.getVariableGroupType("ECP_Composition_CW.ValidatePromotionCartItem_Optimization$vars"))());
vars.value.itemExistsInCartInLocal = itemExistsInCartIn.clone();
vars.value.promotionInLocal = promotionIn.clone();
var listIndexOfCartItemOfferVar = new OS.DataTypes.VariableHolder();
var listIndexOfCartItemPromotionVar = new OS.DataTypes.VariableHolder();
var outVars = new OS.DataTypes.VariableHolder(new (controller.constructor.getVariableGroupType("ECP_Composition_CW.ValidatePromotionCartItem_Optimization$outVars"))());
// CartIsEmpty?
if((!(vars.value.itemExistsInCartInLocal.isEmpty))) {
// EachOffer
// Foreach Promotion.Category.Offers
callContext.iterationContext.registerIterationStart(vars.value.promotionInLocal.categoryAttr.offersAttr);
try {var offersIterator = callContext.iterationContext.getIterator(vars.value.promotionInLocal.categoryAttr.offersAttr);
var offersIndex = 0;
while (((offersIndex < vars.value.promotionInLocal.categoryAttr.offersAttr.length))) {
offersIterator.currentRowNumber = offersIndex;
// HasSingleCategory&Products?
if(((vars.value.promotionInLocal.categoryAttr.offersAttr.getItem(offersIndex.valueOf()).isSingleProductAttr && ((vars.value.promotionInLocal.categoryAttr.offersAttr.getItem(offersIndex.valueOf()).product_SKUAttr) !== (""))))) {
// Execute Action: ListIndexOfCartItemOffer
listIndexOfCartItemOfferVar.value = OS.SystemActions.listIndexOf(vars.value.itemExistsInCartInLocal, function (p) {
return (p.sKUAttr === vars.value.promotionInLocal.categoryAttr.offersAttr.getItem(offersIndex.valueOf()).product_SKUAttr);
}, callContext);

// SetLineItem&Quantity
// Promotion.Category.Offers.Current.Product_LineItemId = If
vars.value.promotionInLocal.categoryAttr.offersAttr.getItem(offersIndex.valueOf()).product_LineItemIdAttr = ((((listIndexOfCartItemOfferVar.value.positionOut) !== (-1))) ? (vars.value.itemExistsInCartInLocal.getItem(listIndexOfCartItemOfferVar.value.positionOut).lineItemIdAttr) : ("0"));
// Promotion.Category.Offers.Current.Product_Quantity = If
vars.value.promotionInLocal.categoryAttr.offersAttr.getItem(offersIndex.valueOf()).product_QuantityAttr = ((((listIndexOfCartItemOfferVar.value.positionOut) !== (-1))) ? (vars.value.itemExistsInCartInLocal.getItem(listIndexOfCartItemOfferVar.value.positionOut).quantityAttr) : (0));
}

offersIndex++;
}

} finally {
callContext.iterationContext.registerIterationEnd(vars.value.promotionInLocal.categoryAttr.offersAttr);
}

// EachProductPromotionTiles
// Foreach Promotion.ProductPromotionBanner.ProductPromotionTiles
callContext.iterationContext.registerIterationStart(vars.value.promotionInLocal.productPromotionBannerAttr.productPromotionTilesAttr);
try {var productPromotionTilesIterator = callContext.iterationContext.getIterator(vars.value.promotionInLocal.productPromotionBannerAttr.productPromotionTilesAttr);
var productPromotionTilesIndex = 0;
while (((productPromotionTilesIndex < vars.value.promotionInLocal.productPromotionBannerAttr.productPromotionTilesAttr.length))) {
productPromotionTilesIterator.currentRowNumber = productPromotionTilesIndex;
// HasProductSKU?
if((((vars.value.promotionInLocal.productPromotionBannerAttr.productPromotionTilesAttr.getItem(productPromotionTilesIndex.valueOf()).productSKUAttr) !== ("")))) {
// Execute Action: ListIndexOfCartItemPromotion
listIndexOfCartItemPromotionVar.value = OS.SystemActions.listIndexOf(vars.value.itemExistsInCartInLocal, function (p) {
return (p.sKUAttr === vars.value.promotionInLocal.productPromotionBannerAttr.productPromotionTilesAttr.getItem(productPromotionTilesIndex.valueOf()).productSKUAttr);
}, callContext);


define("ECP_Cart_CW.Cart.Cart_AddRemoveProducts.mvc$controller.Screen_RemoveItem.RemoveFromCartJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

if($parameters.Quantity !== 0){
    setTimeout(function(){
        $actions.Requests_Increase();
        $actions.Cart_RemoveItemQuantity($parameters.LineItemId,$parameters.SKU_Product,$parameters.Quantity,$parameters.IsOrderEditMode,$parameters.OrderEditId,$parameters.ChannelId).then(function(result) {
       if(result.CallbackOrderEditId){
            $actions.Order_CallbackOrderEdit(result.CallbackOrderEditId);
            } else if(result.IsOrdered) {
                $actions.Screen_IsOrdered(false);
            }else{
                $actions.Screen_CallbackCartUpdate(false, false)
            }
        }).catch(function(error) {

        console.log("Promise error");
        $actions.Screen_ForceRefresh();
        
        });
    },1);
}

};
});


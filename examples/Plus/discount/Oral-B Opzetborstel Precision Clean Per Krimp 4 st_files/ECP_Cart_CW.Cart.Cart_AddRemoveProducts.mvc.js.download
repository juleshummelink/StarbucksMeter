define("ECP_Cart_CW.Cart.Cart_AddRemoveProducts.mvc$controller.OnClick_AddRemoveProduct.SecureCallToUpdate_V2JS", [], function () {
return function ($parameters, $actions, $roles, $public) {
function createUpdateCartHandler() {
    //Retry mechanism variables
    const maxRetryAttempts = $parameters.RetryMechanismMaxRetries;
    let retryCount = 0;

    function updateCart() {
        $actions.Cart_Update($parameters.OneWelcomeUserId, $parameters.LineItem_Id,$parameters.SKU_Product,$parameters.IncrementQuantity, $parameters.ChannelId,$parameters.ItemListName, $parameters.ProductRowNumber, $parameters.CitrusAdId).then(function(result){
        if(result.CallbackOrderEditId){
                $actions.Order_CallbackOrderEdit(result.CallbackOrderEditId);
        } else if(result.IsOrdered) { 
                $actions.Screen_IsOrdered(result.IsAdd);
            } else {
                $actions.Screen_CallbackCartUpdate(result.ForceRefresh, result.IsToShowFeedbackMessage);
                
                if(result.LineItemId_Out !== ""){
                    $actions.Screen_UpdateLineItem(result.LineItemId_Out);
                }
            }
        
        }).catch(function(error) {
            console.log("Promise error");
            if($actions.JSON_ValidateWithStructure(error.message).IsValid && JSON.parse(error.message).ExceptionName=="UnknowCart")
                $actions.Handle401Exception();
            else {
                // Retry logic
                if (retryCount < maxRetryAttempts) {
                    retryCount++;
                    console.log("Retrying Cart_Update. Attempt: " + retryCount + " Product SKU:" + $parameters.SKU_Product);
                    updateCart();
                } else {
                    $actions.Screen_ForceRefresh();
                    $actions.Set_EnableMinusButton(true);
                }
            }
        });
    }
    return updateCart;
}

// Call createUpdateCartHandler to get the encapsulated updateCart function
const updateCartHandler = createUpdateCartHandler();

$parameters.TimeoutId_Out = setTimeout(function(){
    $actions.Requests_Increase();
    if($parameters.LineItem_Id  === "") {
        $actions.Set_EnableMinusButton(false);
    }

    // Initial call to updateCart function
    updateCartHandler();
    
    $actions.Screen_UpdateBaseQuantity($parameters.IncrementQuantity);
}, $parameters.DelayTime);



};
});
define("ECP_Cart_CW.Cart.Cart_AddRemoveProducts.mvc$controller.OnDestroy.clearTimeoutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
clearTimeout($parameters.TimeoutId);

}

$parameters.query_cols.cols_1.addEventListener('change', $actions.Callback_Columns_1);

$parameters.query_cols.cols_2.addEventListener('change', $actions.Callback_Columns_2);

$parameters.query_cols.cols_3.addEventListener('change', $actions.Callback_Columns_3);

$parameters.query_cols.cols_4.addEventListener('change', $actions.Callback_Columns_4);



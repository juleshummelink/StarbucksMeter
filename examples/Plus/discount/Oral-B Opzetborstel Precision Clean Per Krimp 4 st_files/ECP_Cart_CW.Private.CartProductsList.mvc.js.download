define("ECP_Cart_CW.Private.CartProductsList.mvc$controller.OnSwipe_RemoveItem.AsyncRemoveItemJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

$parameters.TimeoutId = setTimeout(function(){
    $actions.Cart_RemoveItemQuantity($parameters.LineItem,$parameters.SKU_Product,$parameters.Quantity,$parameters.IsOrderEditMode,$parameters.OrderEditId,$parameters.OrderEditVersion,$parameters.ChannelId).then(function(result){
       if(result.CallbackOrderEditId){
            $actions.Order_CallbackOrderEdit(result.CallbackOrderEditId);
            } else if(result.IsOrdered) {
            $actions.Handler_CartOrdered(false);
        }else{
            $actions.Handler_CartUpdated(true);
        }
    });
},10);
};
});


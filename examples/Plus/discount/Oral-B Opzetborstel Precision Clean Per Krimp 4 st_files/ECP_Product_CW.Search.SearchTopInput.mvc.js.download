define("ECP_Product_CW.Search.SearchTopInput.mvc$controller.OnKeydown_Input.ShiftTabJS", [], function () {
return function ($actions, $roles, $public) {
if(window.event.shiftKey && window.event.keyCode == 9) { 
    //shift was down when tab was pressed
    $actions.Screen_HideDropdownContent();
}
};
});

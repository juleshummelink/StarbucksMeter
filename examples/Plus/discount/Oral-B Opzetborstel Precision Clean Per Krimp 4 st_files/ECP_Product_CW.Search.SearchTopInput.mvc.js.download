define("ECP_Product_CW.Search.SearchTopInput.mvc$controller.OnKeyUp_Input.EnterKeyPressedJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if(window.event.keyCode==13){
    
    const emojiRegex = /[^\p{L}\p{N}\p{P}\p{Z}]/gu;
    const check = emojiRegex.test($parameters.SearchText);

    if (check) {
        //  String Has Emoji
        const sanitizedSearch = $parameters.SearchText.replace(/[^\p{L}\p{N}\p{P}\p{Z}]/gu,'');
        if (!sanitizedSearch.replace(/\s/g, '').length) { 
                //string only has spaces 
                $actions.Screen_Search("");
        } else {
            $actions.Screen_Search(sanitizedSearch.trim().replace(/\s{2,}/g,' ')); //removes any space from the start  and end of the string 
        }
        
    } else {
        //No need to filter  
        $actions.Screen_Search($parameters.SearchText);
    } 

}

};
});
define("ECP_Product_CW.Search.SearchTopInput.mvc$controller.OnKeyUp_Input.EscapeKeyPressedJS", [], function () {
return function ($actions, $roles, $public) {
if(window.event.keyCode==27){
    $actions.ClearAndUnfocus();
}
};
});
define("ECP_Product_CW.Search.SearchTopInput.mvc$controller.OnChange_Input.EmojiCheckJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const emojiRegex = /[^\p{L}\p{N}\p{P}\p{Z}]/gu;
const check = emojiRegex.test($parameters.SearchTerm);

if (check) {
            //  String Has Emoji
            
            const sanitizedSearch = $parameters.SearchTerm.replace(/[^\p{L}\p{N}\p{P}\p{Z}]/gu,'');
            if (!sanitizedSearch.replace(/\s/g, '').length) { 
                //string only has spaces 
                $parameters.SanitizeSearch ="";
        } else {
            $parameters.SanitizeSearch = sanitizedSearch.trim().replace(/\s{2,}/g,' '); //removes any space from the start  and end of the string 
        }
        setTimeout(function() {document.getElementById($parameters.InputId).value = $parameters.SanitizeSearch;}, 10);

    } else {
        //No need to filter  
        $parameters.SanitizeSearch = $parameters.SearchTerm ;
    } 
};
});

define("ECOP_Base_RPat.controller$UpdateSidebarContent.UpdateSidebarContentJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
// Sidebar API instance.
let sidebarInstance = null;

// Ensure OutSystems UI API is available.
if (typeof OutSystems !== 'undefined' && OutSystems.OSUI && OutSystems.OSUI.Patterns && OutSystems.OSUI.Patterns.SidebarAPI) {

    let targetSidebarAsideElement = null; // Found <aside> DOM element.

    // --- Step 1: Attempt to find the sidebar based on $parameters.ElementID (if provided). ---
    if ($parameters.ElementID) {
        let elementId = $parameters.ElementID;
        // Get the HTML element directly by its ID.
        let sourceElement = document.getElementById(elementId);

        if (sourceElement) {
            // Prioritize finding the sidebar related to this sourceElement.

            // 1. Check if the sourceElement itself is an open, named <aside>.
            if (sourceElement.tagName.toLowerCase() === 'aside' &&
                sourceElement.classList.contains('osui-sidebar--is-open') &&
                sourceElement.hasAttribute('name')) {
                targetSidebarAsideElement = sourceElement;
            }

            // 2. If still not found, check if an ancestor of sourceElement is an open, named <aside>.
            // This covers the case where $parameters.ElementID is for an element *inside* the sidebar.
            if (!targetSidebarAsideElement) {
                targetSidebarAsideElement = sourceElement.closest('.osui-sidebar--is-open');
            }
        }
    }

    // --- Step 2: If the sidebar was not found yet, search for ANY open sidebar (general fallback). ---
    if (!targetSidebarAsideElement) {
        targetSidebarAsideElement = document.querySelector('.osui-sidebar--is-open');
    }

    // --- Step 3: If an <aside> element was found, get the API instance. ---
    if (targetSidebarAsideElement && targetSidebarAsideElement.hasAttribute('name')) {
        let sidebarName = targetSidebarAsideElement.getAttribute('name');
        sidebarInstance = OutSystems.OSUI.Patterns.SidebarAPI.GetSidebarById(sidebarName);
    }

    // --- Final Action: Call setHtmlElements() if a valid sidebar instance was found. ---
    if (sidebarInstance) {
        sidebarInstance.setHtmlElements();
    }
}
};
});


define("ECOP_Base_RPat.controller$Validation_NumbersOnly.NumberOnlyJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
function allowNumbersOnly(event) {
  // Get the keyboard event
  var keyCode = event.which || event.keyCode;

  // Allow backspace, delete, arrow keys, tab, enter, and escape
  if (  keyCode === 8 || // Backspace
        keyCode === 46 || // Delete
        keyCode === 9 || // Tab
        keyCode === 13 || // Enter
        keyCode === 27 || // Escape
        (keyCode >= 37 && keyCode <= 40) || //Arrows Left, Uo, Right, Down
        (keyCode >= 96 && keyCode <= 105) || //numpad numbers
        keyCode === 67 && (event.ctrlKey || event.metaKey) || // Ctrl+C
        keyCode === 88 && (event.ctrlKey || event.metaKey) || // Ctrl+X
        keyCode === 86 && (event.ctrlKey || event.metaKey) // Ctrl+V
   ) {
    return true;
  }

  // Convert the keycode to a string
  var keyChar = String.fromCharCode(keyCode);

  // Test if the key character is a number
  var regex = /[0-9]/;
  if (!regex.test(keyChar)) {
    // If it's not a number, prevent the default behavior
    event.preventDefault();
    return false;
  }

  // If we get here, the input is valid
  return true;
}

function allowNumbersOnlyOnPaste(event) {
      // Get the clipboard data
      var clipboardData = event.clipboardData || window.clipboardData;
      
      // Get the pasted text
      var pastedText = clipboardData.getData('text');
      
      // Validate if the pasted text contains only numbers
      if (!/^\d+$/.test(pastedText)) {
        event.preventDefault(); // Prevent pasting non-numeric characters
      }
}

// Add the allowNumbersOnly function to the onkeypress event of an input element with a specific ID
document.getElementById($parameters.InputId).onkeydown = allowNumbersOnly;
document.getElementById($parameters.InputId).onpaste = allowNumbersOnlyOnPaste;
};
});


define("ECOP_Base_RPat.controller$Format_FullDate.FormatDateToLocaleFormatJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var date = new Date($parameters.Date);

var options = { day: 'numeric', month: 'long', year: 'numeric' };
if($parameters.IsShortMonth){
    options = { day: 'numeric', month: 'short', year: 'numeric' };
}

var lang = "";
try{
    lang = document.querySelector('html').getAttribute('lang');
    if(!lang){
       lang = $parameters.DefaultLang; 
    }
}catch(e){
    lang = $parameters.DefaultLang;
}

$parameters.DateText = date.toLocaleDateString(lang, options);

};
});


define("ECOP_Base_RPat.controller$InitTimer.InitJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var el = document.getElementById($parameters.timerContainerId)

var dateStart = Date.now();
var dateEnd = dateStart;
dateEnd = (dateEnd + (1000 * el.totalSeconds));

if ( isNaN(dateEnd) ) {
return;
}

el.dateStart = dateStart;
el.dateEnd = dateEnd;

if($parameters.startAtBeginning){
    $actions.ContinueTimer($parameters.timerContainerId);
    $parameters.timer  = el.timer;
} else {
    el.stepFunction();
}

};
});

define("ECOP_Base_RPat.controller$InputMask_GetServerDateFormat", ["exports", "OutSystems/ClientRuntime/Main", "ECOP_Base_RPat.model", "ECOP_Base_RPat.controller"], function (exports, OutSystems, ECOP_Base_RPatModel, ECOP_Base_RPatController) {

define("ECOP_Base_RPat.controller$Format_NoYearDate.FormatDateToLocaleFormatJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var date = new Date($parameters.Date);

var options = { day: 'numeric', month: 'long'};
if($parameters.IsShortMonthName)
    options = { day: 'numeric', month: 'short'};
    
var lang = document.querySelector('html').getAttribute('lang');
    
if(!lang)
    lang = 'nl-NL'; /* Set to default that is Dutch */

if($parameters.IsLowerCase){
        $parameters.DateText = date.toLocaleDateString(lang, options).toLowerCase();
    } else { 
        $parameters.DateText = date.toLocaleDateString(lang, options);
    }
};
});


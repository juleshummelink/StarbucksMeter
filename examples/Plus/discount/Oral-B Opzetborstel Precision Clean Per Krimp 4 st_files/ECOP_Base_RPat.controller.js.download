define("ECOP_Base_RPat.controller$JS_ScrollToElement_Smooth.ScrollSmoothJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var element;
if($parameters.IsByCSS_Selector){
    element = document.querySelector($parameters.ElementCSSSelector);
}
else{
    element = document.getElementById($parameters.ElementId);
}

if(element){
    if(document.querySelector('body.ios')){
        if(document.querySelector($parameters.ScrollableElement)){
            var eTop = element.getBoundingClientRect().top;
            var eAmt = eTop / 100;
            var curTime = 0;
            while (curTime <= $parameters.Time) {
                window.setTimeout(function(){
                    var ctnt = document.querySelector($parameters.ScrollableElement);
                    if(ctnt)
                        ctnt.scrollBy(0, eAmt);
                }, curTime);
                curTime += $parameters.Time / 100;
            }
        }
    }
    else{
        element.scrollIntoView({ behavior: 'smooth', block: 'start'});
    }
}


};
});


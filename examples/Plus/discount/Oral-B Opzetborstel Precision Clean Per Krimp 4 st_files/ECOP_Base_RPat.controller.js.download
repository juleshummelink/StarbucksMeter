define("ECOP_Base_RPat.controller$SetInputLengthLimit.CheckLengthJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
// Get the input element
var input = document.getElementById($parameters.InputId);

// Store the previous valid value
var previousValue = '';

function checkLength() {
   // Check if the input value exceeds the maximum length of characters
  if (input.value.length > $parameters.MaxInputLength) {
    // Restore the previous valid value
    input.value = previousValue;
  } else {
    // Update the previous valid value
    previousValue = input.value;
  }
}

// Adds the checkLength() function to the input event of an input element with a specific ID
document.getElementById($parameters.InputId).addEventListener('input', checkLength);


};
});


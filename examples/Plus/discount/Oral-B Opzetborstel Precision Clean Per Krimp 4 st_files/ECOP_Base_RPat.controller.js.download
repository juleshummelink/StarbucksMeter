define("ECOP_Base_RPat.controller$BannerPlacement.BannerPlacementJSJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
//List of items in the grid
let items = document.querySelectorAll($parameters.ItemsListSelector);
//Banner list
let plpBannerList = document.querySelectorAll($parameters.BannerListSelector);
//Hidden banner list
let hiddenBannerList = document.querySelectorAll($parameters.HiddenBannerListSelector);
//Grid where the items are placed
let grid = document.querySelector($parameters.GridSelector);
//Index of the banner in plpBannerList
let plpBannerIndex = 0;
//Index of the banner in hiddenBannerList
let hiddenBannerIndex = 0;
//Index of the item in the list of items of the grid
let itemIndex = 0;
//Parameter that defines the gap between banners 
let gap;
//Banner Placement starting position after the first banner placement
let secondPos;
//Number of columns in a grid row
let nColumns;
//if the input parameter NColumns is defined than the nColumns is defined by it
if($parameters.NColumns !== 0){
    nColumns = $parameters.NColumns;
}else{
    //else it will be calculated
    nColumns = window.getComputedStyle(grid).gridTemplateColumns.split(' ').length;
}
//According to the number of columns in a row, the gap and the secondPos is calculated
    switch (nColumns) {
        case 2:
            gap = 4;
            secondPos = 6;
            break;
        case 3:
            gap = 6;
            secondPos = 9;
            break;
        case 4:
            gap = 8;
            secondPos = 12;
            break;
        default:
            gap = nColumns;
            break;
    }

if($parameters.IsMobile){
    itemIndex = 4;
    secondPos = 10;
}else{
    itemIndex = nColumns;
}

if(items.length > nColumns){
    //checks if there are banners waiting to be placed
    if (plpBannerIndex < plpBannerList.length) {
        if($parameters.IsMobile){
            items[nColumns].parentNode.insertBefore(plpBannerList[plpBannerIndex], items[itemIndex]);
        } else{
            items[nColumns].parentNode.insertBefore(plpBannerList[plpBannerIndex], items[nColumns])
        }
        //adds 1 to plpBannerIndex
        plpBannerIndex++;
        //it resets the itemIndex to be equal to secondPos calculated earlier
        itemIndex = secondPos;
    } else if (hiddenBannerIndex < hiddenBannerList.length) {
        items[itemIndex].parentNode.insertBefore(hiddenBannerList[hiddenBannerIndex], items[itemIndex]);
        //adds 1 to hiddenBannerIndex
        hiddenBannerIndex++;
        //it resets the itemIndex to be equal to secondPos calculated earlier
        itemIndex = secondPos;
    }

    //Cycles to list of items and places a banner every number of items (gap)
    for(itemIndex; itemIndex < items.length; itemIndex+=gap){
            if(plpBannerIndex !== plpBannerList.length) {
                items[itemIndex].parentNode.insertBefore(plpBannerList[plpBannerIndex], items[itemIndex]);
                plpBannerIndex++;
            } else if(hiddenBannerIndex !== hiddenBannerList.length) {
                items[itemIndex].parentNode.insertBefore(hiddenBannerList[hiddenBannerIndex], items[itemIndex]);
                hiddenBannerIndex++;   
            } else {
                return
            }
    }
    
    for(plpBannerIndex; plpBannerIndex < plpBannerList.length; plpBannerIndex++) {
        if(hiddenBannerList.length > 0) {
            hiddenBannerList[0].parentNode.insertBefore(plpBannerList[plpBannerIndex],hiddenBannerList[0]);
        } else {
            if($parameters.TotalItems !== items.length){
                document.querySelector($parameters.BannerWrapperSelector).appendChild(plpBannerList[plpBannerIndex]);
            }
            
        }
        
    }
}

//checks if the number of items in the grid is equal to the total number of items of the query
if($parameters.TotalItems === items.length && hiddenBannerIndex < hiddenBannerList.length){
    //checks if the last element of the grid is a banner. If true, a banner is placed
    if(grid.lastElementChild.tagName !== 'DIV'){
         grid.append(hiddenBannerList[hiddenBannerIndex]);
    }
}




};
});


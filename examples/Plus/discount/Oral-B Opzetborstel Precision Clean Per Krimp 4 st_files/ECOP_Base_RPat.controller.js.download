outVars.value.dateFormatOut = OS.BuiltinFunctions.replace(outVars.value.dateFormatOut, "11", "mm");
// DateFormat = Replace
outVars.value.dateFormatOut = OS.BuiltinFunctions.replace(outVars.value.dateFormatOut, "23", "dd");
return outVars.value;
};

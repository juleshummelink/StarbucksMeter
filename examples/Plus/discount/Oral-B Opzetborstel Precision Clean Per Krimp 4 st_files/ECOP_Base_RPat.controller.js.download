define("ECOP_Base_RPat.controller$JSONPath.JSONPathJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var jsonPathResult;

if($parameters.Options) {
    var jsonObjectWithOptions = buildJsonObjectWithOptions($parameters.Path,$parameters.JSON,$parameters.Options);
    jsonPathResult = JSONPath.JSONPath(jsonObjectWithOptions);
    
} else {
    var jsonObject = JSON.parse($parameters.JSON);
    jsonPathResult = JSONPath.JSONPath({path:$parameters.Path, json:jsonObject});   
}

// When using the JSONpath option "{"wrap":false} the response is no longer 
// an array in case 1 or 0 resulst are returned. 
// When multiple results are returned, response is always an array.

//Check the JSONpath lib options in the comment of the action

//Array returned so we can get the length (more than 1 result)
if(Array.isArray(jsonPathResult)) {
    $parameters.Result = JSON.stringify(jsonPathResult);
    $parameters.ResultCount = jsonPathResult.length;
    return;
}

// undefined, so wrap:false was set and no results were found
if(jsonPathResult === undefined) {
    $parameters.Result = "";
    $parameters.ResultCount = 0;
    return;
}

// If response is not an array or undefined, it means wrap:false was set and only one result found
$parameters.Result = JSON.stringify(jsonPathResult);
$parameters.ResultCount = 1;


// Helper function
// This function builds the JSON object to pass as input parameter when options are provided
function buildJsonObjectWithOptions(path, jsonAsString, options) {
   
    var optionsObject = JSON.parse(options);
    var pathObject = JSON.parse(JSON.stringify({path: path}));
    var jsonObject = JSON.parse(JSON.stringify({json: JSON.parse(jsonAsString)}));
    
    return JSON.parse(JSON.stringify(Object.assign(optionsObject,pathObject,jsonObject)));
}
};
});


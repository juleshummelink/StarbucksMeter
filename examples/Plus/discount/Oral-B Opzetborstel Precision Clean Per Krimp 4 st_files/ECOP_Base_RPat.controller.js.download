define("ECOP_Base_RPat.controller$Calculate.CalculateJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var el = document.getElementById($parameters.timerContainerId)
var dateEnd = el.dateEnd;
var dateStart = el.dateStart;

$parameters.timeRemainingMsOut = parseInt((dateEnd - dateStart))
$parameters.timeRemainingOut = $parameters.timeRemainingMsOut / 1000;
var timeRemaining = $parameters.timeRemainingOut;


$parameters.totalSeconds = parseInt(el.totalSeconds,10);

if ( timeRemaining >= 0 ) {
    days    = parseInt(timeRemaining / 86400);
    timeRemaining   = (timeRemaining % 86400);
    hours   = parseInt(timeRemaining / 3600);
    timeRemaining   = (timeRemaining % 3600);
    minutes = parseInt(timeRemaining / 60);
    timeRemaining   = (timeRemaining % 60);
    seconds = parseInt(timeRemaining);

    daysHTML = el.getElementsByClassName('timer-days')[0];
    
    if(daysHTML)
    {
        daysHTML.innerHTML    = parseInt(days, 10);
    }
    
    hoursHTML = el.getElementsByClassName('timer-hours')[0];
    if(hoursHTML)
    {
        hoursHTML.innerHTML   = ("0" + hours).slice(-2);
    }
    
    minutesHTML = el.getElementsByClassName('timer-minutes')[0];
    if(minutesHTML)
    {
        minutesHTML.innerHTML = ("" + minutes).slice(-2);
    }
    
    secondsHTML = el.getElementsByClassName('timer-seconds')[0];
    if(secondsHTML)
    {
    secondsHTML.innerHTML = ("0" + seconds).slice(-2);
    }
    
    el.dateEnd = dateEnd - el.stepDuration;
} else {
    if(  typeof(el.callBackFunction) === typeof(Function))
    {
        clearInterval(el.timer);
        el.callBackFunction();

    }
    return;
}


    
    

};
});


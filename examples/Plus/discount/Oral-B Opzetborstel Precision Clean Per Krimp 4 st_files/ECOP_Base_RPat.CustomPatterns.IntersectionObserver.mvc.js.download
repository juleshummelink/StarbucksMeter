define("ECOP_Base_RPat.CustomPatterns.IntersectionObserver.mvc$controller.OnReady.ObserverConstructorJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
return new Promise(function ($resolve, $reject) {
try {
    let options      = {};
    let root         = $parameters.UseScreenContainerAsRootElement ? document.getElementsByClassName("active-screen screen-container")[0] : document.getElementById($parameters.RootElementWidgetId);
    let target       = document.getElementById($parameters.TargetElementWidgetId);
    let rootMargin   = $parameters.RootMargin;
    let scrollMargin = $parameters.ScrollMargin;
    let threshold    = JSON.parse($parameters.ThresholdJSON);
    
    options.root        = root;
    options.rootMargin  = rootMargin;
    options.threshold   = threshold;
    options.scrollMargin = scrollMargin;
    
    let observer = new IntersectionObserver($actions.IntersectCallback, options);
    
    observer.observe(target);
    
    $parameters.ObserverObject = observer;

    $resolve();
}
catch(error) {
    $parameters.IsError = true;
    $parameters.ErrorMessage = error.message;
    console.log('Error: ',error);

    $resolve();
}
});
};
});

define("ECOP_Base_RPat.CustomPatterns.IntersectionObserver.mvc$controller.IntersectCallback.StringifyJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
return new Promise(function ($resolve, $reject) {
let obj = $parameters.Object;
let inter = [];

try {
    obj.forEach((item) => {
        let ioe = {};
        ioe.boundingClientRect={};
        ioe.intersectionRect={};
        ioe.rootBounds={};
        
        ioe.boundingClientRect.bottom = item.boundingClientRect.bottom;
        ioe.boundingClientRect.height = item.boundingClientRect.height;
        ioe.boundingClientRect.left = item.boundingClientRect.left;
        ioe.boundingClientRect.right = item.boundingClientRect.right;
        ioe.boundingClientRect.top = item.boundingClientRect.top;
        ioe.boundingClientRect.width = item.boundingClientRect.width;
        ioe.boundingClientRect.x = item.boundingClientRect.x;
        ioe.boundingClientRect.y = item.boundingClientRect.y;
        
        ioe.intersectionRect.bottom = item.intersectionRect.bottom;
        ioe.intersectionRect.height = item.intersectionRect.height;
        ioe.intersectionRect.left = item.intersectionRect.left;
        ioe.intersectionRect.right = item.intersectionRect.right;
        ioe.intersectionRect.top = item.intersectionRect.top;
        ioe.intersectionRect.width = item.intersectionRect.width;
        ioe.intersectionRect.x = item.intersectionRect.x;
        ioe.intersectionRect.y = item.intersectionRect.y;
        
        // rootBounds is not always available
        if (item.rootBounds !== null){
            ioe.rootBounds.bottom = item.rootBounds.bottom;
            ioe.rootBounds.height = item.rootBounds.height;
            ioe.rootBounds.left = item.rootBounds.left;
            ioe.rootBounds.right = item.rootBounds.right;
            ioe.rootBounds.top = item.rootBounds.top;
            ioe.rootBounds.width = item.rootBounds.width;
            ioe.rootBounds.x = item.rootBounds.x;
            ioe.rootBounds.y = item.rootBounds.y;    
        }
        
        ioe.intersectionRatio = item.intersectionRatio;
        ioe.isIntersecting = item.isIntersecting;
        ioe.isVisible = item.isVisible;
        ioe.targetID = item.target.id;
        ioe.time = item.time;
    
        inter.push(ioe);
    
    });
    
    $parameters.JSON = JSON.stringify(inter);

    $resolve();
}
catch(error)
{
    $parameters.IsError = true;
    $parameters.ErrorMessage = error.message;
    console.log('Error: ',error);
    
    $resolve();
}

});
};
});


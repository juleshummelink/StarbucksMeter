Controller.prototype._screen_CheckVoucherForNewDay$Action = function (callContext) {
var model = this.model;
var controller = this.controller;
var idService = this.idService;
controller.ensureControllerAlive("Screen_CheckVoucherForNewDay");
callContext = controller.callContext(callContext);
var cart_GetVoucherList_Temp_RMVar = new OS.DataTypes.VariableHolder();
var listIndexOfVar = new OS.DataTypes.VariableHolder();
var voucher_ValidateForDayVar = new OS.DataTypes.VariableHolder();
// Execute Action: Cart_GetVoucherList_Temp_RM
cart_GetVoucherList_Temp_RMVar.value = ECP_Cart_CWController.default.cart_GetVoucherList_Temp_RM$Action(callContext);

// Has voucher selected?
if((!(cart_GetVoucherList_Temp_RMVar.value.voucherListOut.isEmpty))) {
// Execute Action: ListIndexOf
listIndexOfVar.value = OS.SystemActions.listIndexOf(model.variables.getCouponListDataAct.couponListOut, function (p) {
return (p.voucherAttr.coupon_ExternalCodeAttr === cart_GetVoucherList_Temp_RMVar.value.voucherListOut.getCurrent(callContext.iterationContext).externalCodeAttr);
}, callContext);

// Found selection?
if((((listIndexOfVar.value.positionOut) !== (-1)))) {
// IsApplied = True
// GetCouponList.CouponList[ListIndexOf.Position].Voucher.Coupon_IsApplied = True
model.variables.getCouponListDataAct.couponListOut.getItem(listIndexOfVar.value.positionOut).voucherAttr.coupon_IsAppliedAttr = true;
}

} else {
// Coupon list
// Foreach GetCouponList.CouponList
callContext.iterationContext.registerIterationStart(model.variables.getCouponListDataAct.couponListOut);
try {var couponListIterator = callContext.iterationContext.getIterator(model.variables.getCouponListDataAct.couponListOut);
var couponListIndex = 0;
while (((couponListIndex < model.variables.getCouponListDataAct.couponListOut.length))) {
couponListIterator.currentRowNumber = couponListIndex;
// Is applied?
if((model.variables.getCouponListDataAct.couponListOut.getItem(couponListIndex.valueOf()).voucherAttr.coupon_IsAppliedAttr)) {
// IsApplied = False
// GetCouponList.CouponList.Current.Voucher.Coupon_IsApplied = False
model.variables.getCouponListDataAct.couponListOut.getItem(couponListIndex.valueOf()).voucherAttr.coupon_IsAppliedAttr = false;
}

couponListIndex++;
}

} finally {
callContext.iterationContext.registerIterationEnd(model.variables.getCouponListDataAct.couponListOut);
}

}

// Execute Action: Voucher_ValidateForDay
voucher_ValidateForDayVar.value = ECOP_FE_CoreController.default.voucher_ValidateForDay$Action(model.variables.oneWelcomeUserIdIn, model.variables.getCouponListDataAct.couponListOut, model.variables.localCheckoutVar.reservedMomentAttr.deliveryDateAttr, callContext);

// Toggle ShowPromotionDateMessage
// LocalCheckout.Receipt.VoucherList.Current.Description = Cart_GetVoucherList_Temp_RM.VoucherList.Current.Description
model.variables.localCheckoutVar.receiptAttr.voucherListAttr.getCurrent(callContext.iterationContext).descriptionAttr = cart_GetVoucherList_Temp_RMVar.value.voucherListOut.getCurrent(callContext.iterationContext).descriptionAttr;
// VoucherRec.ShowOfferErrorMessage = notVoucher_ValidateForDay.IsValid
model.variables.voucherRecVar.showOfferErrorMessageAttr = !(voucher_ValidateForDayVar.value.isValidOut);
// VoucherRec.Description = LocalCheckout.Receipt.VoucherList.Current.Description
model.variables.voucherRecVar.descriptionAttr = model.variables.localCheckoutVar.receiptAttr.voucherListAttr.getCurrent(callContext.iterationContext).descriptionAttr;
};

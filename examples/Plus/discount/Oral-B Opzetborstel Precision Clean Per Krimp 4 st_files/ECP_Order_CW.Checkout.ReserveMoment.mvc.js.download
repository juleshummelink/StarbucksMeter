define("ECP_Order_CW.Checkout.ReserveMoment.mvc$controller.ServicesSlectorMessage.ServiceSelectorMessage2JS", [], function () {
return function ($parameters, $actions, $roles, $public) {
// Delivery logic
if (!$parameters.IsLoggedIn) {
    $parameters.text_delivery = "Log in om zeker te zijn dat de geselecteerde winkel op jouw afleveradres bezorgt.";
} 
else if (
    $parameters.IsLoggedIn &&
    $parameters.HasAddress &&
    $parameters.StoreHasDeliveryService &&
    !$parameters.HasDelivery &&
    !$parameters.StoreDeliversToZip
) {
    $parameters.text_delivery = "De geselecteerde winkel bezorgt niet op het opgegeven adres. Kies een andere winkel of wijzig je afleveradres om je boodschappen te laten bezorgen.";
}
else if (
    !$parameters.StoreHasDeliveryService 
) {
    const hasPickup = $parameters.StoreHasPickupService && $parameters.HasPickup;
    $parameters.text_delivery = hasPickup
        ? "De geselecteerde winkel biedt geen bezorgservice aan. Kies een andere winkel in de buurt om je boodschappen te laten bezorgen. Je kan er ook voor kiezen om je boodschappen op te halen."
        : "De geselecteerde winkel biedt geen bezorgservice aan. Kies een andere winkel in de buurt om je boodschappen te laten bezorgen.";
} 

else if (!$parameters.HasAddress && !$parameters.HasDelivery && !$parameters.HasAddress && !$parameters.StoreDeliversToZip) {
    $parameters.text_delivery = "Er is nog geen adres opgeslagen in je account. Stel een adres in om je boodschappen te kunnen laten bezorgen."; // C  
}
else if (!$parameters.HasAddress && $parameters.StoreHasDeliveryService && !$parameters.HasDelivery && !$parameters.HasPickup && !$parameters.StoreDeliversToZip ) {
    $parameters.text_delivery = "Er zijn op dit moment geen momenten beschikbaar voor bezorgen. Kies een andere winkel in de buurt om je boodschappen te laten bezorgen.";  // J
} 
else if ($parameters.HasAddress && $parameters.StoreHasDeliveryService && !$parameters.HasDelivery  && !$parameters.HasPickup && $parameters.StoreDeliversToZip ) {
    $parameters.text_delivery = "Er zijn op dit moment geen momenten beschikbaar voor bezorgen. Kies een andere winkel in de buurt om je boodschappen te laten bezorgen.";  // J
} 
else if (!$parameters.HasAddress ) {
    $parameters.text_delivery = "Er is nog geen adres opgeslagen in je account. Stel een adres in om je boodschappen te kunnen laten bezorgen."; // C  
} 
else if (!$parameters.StoreDeliversToZip) {
    $parameters.text_delivery = "De geselecteerde winkel bezorgt niet op het opgegeven adres. Kies een andere winkel of wijzig je afleveradres om je boodschappen te laten bezorgen."; // D
} 
else if( !$parameters.HasDelivery && $parameters.StoreHasPickupService && $parameters.HasPickup && $parameters.HasAddress && $parameters.StoreDeliversToZip) {
        $parameters.text_delivery = "Er zijn op dit moment geen momenten beschikbaar voor bezorgen. Kies een andere winkel in de buurt om je boodschappen te laten bezorgen. Je kan er ook voor kiezen om je boodschappen op te halen." // K
        
}
else if (!$parameters.HasMinimalAmount) {
    $parameters.text_delivery = "Je bestelling voldoet niet aan het minimale bestelbedrag van "+ $parameters.MimAmount+ " euro."; // E 
} 
else {
    $parameters.text_delivery = "Active";
}

// Pickup logic
const noPickupAvailable = !$parameters.StoreHasPickupService 
if (noPickupAvailable) {
    $parameters.text_pickup = $parameters.text_delivery === "Active"
        ? "De geselecteerde winkel biedt geen ophaalservice aan. Kies een andere winkel in de buurt om je boodschappen op te halen. Je kan er ook voor kiezen om je boodschappen te laten bezorgen." // H
        : "De geselecteerde winkel biedt geen ophaalservice aan. Kies een andere winkel in de buurt om je boodschappen op te halen." // G
} else if (
        !$parameters.HasPickup  // No capacity -> All values TRUE but no Timeslots -> New store with no timeslots defined in the next 28 days OR Store with 0 Capacity in the next 28 days
) {
    const hasPickup = $parameters.StoreHasDeliveryService && $parameters.HasDelivery && $parameters.HasMinimalAmount && $parameters.HasAddress && $parameters.StoreDeliversToZip;
    $parameters.text_pickup = hasPickup
        ? "Er zijn op dit moment geen momenten beschikbaar voor ophalen. Kies een andere winkel in de buurt om je boodschappen op te halen. Je kan er ook voor kiezen om je boodschappen te laten bezorgen." // M
        : "Er zijn op dit moment geen momenten beschikbaar voor ophalen. Kies een andere winkel in de buurt om je boodschappen op te halen.";  // L
} else {
    $parameters.text_pickup = "Active";
}
};
});

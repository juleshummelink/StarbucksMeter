define("ECP_Order_CW.Checkout.ReserveMoment.mvc$controller.FocusTimeSlot.FocusWithTimeoutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var z = document.getElementById($parameters.WidgetId);

if (z && z.getElementsByTagName('div').length > 0) {
    setTimeout(
        function() {
            z.getElementsByTagName('div')[0].focus();
        },
    0);
}
};
});


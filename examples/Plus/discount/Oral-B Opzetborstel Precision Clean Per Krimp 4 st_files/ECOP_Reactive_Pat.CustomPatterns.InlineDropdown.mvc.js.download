return function ($actions, $roles, $public) {
const el = document.querySelector('.popover');

if (el) {
    el.firstChild.setAttribute('aria-expanded', 'false');
    el.firstChild.setAttribute('role', 'button');
  // Create a MutationObserver to watch changes in the class attribute
  const observer = new MutationObserver(() => {
    // Check if the 'popover-expanded' class is present
    const isExpanded = el.classList.contains('popover-expanded');
    el.firstChild.setAttribute('aria-expanded', isExpanded.toString());    
});

  const config = {attributes: true};
  observer.observe(el, config);
} 
};
});


return function ($parameters, $actions, $roles, $public) {
if(document.body.classList.contains('phone')) {
    $parameters.AmountOfCategoriesShown = 8
} else {
    if(document.body.classList.contains('tablet') || (document.body.classList.contains('desktop') && window.innerWidth < 1099)) {
        $parameters.AmountOfCategoriesShown = 9
    } else {
        $parameters.AmountOfCategoriesShown = window.innerWidth > 1441 ? 10 : 8;
    }
}
};
});

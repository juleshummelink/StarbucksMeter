define("ECP_Store_CW.StoreFlow.StoreSelection_FlyIIn.mvc$controller.OnRender.RemoveRoleJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
document.getElementById($parameters.SearchLinkId).removeAttribute("role");
document.getElementById($parameters.SearchLinkId).removeAttribute("href");
};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_FlyIIn.mvc$controller.ValidateZipcode.IsZipcodeJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if($parameters.PostalCode.match(/^[1-9][0-9]{3} ?(?!sa|sd|ss)[a-z]{2}?$/i)) {
    $parameters.IsValid = true;
}else {
    $parameters.IsValid = false;
}


};
});
define("ECP_Store_CW.StoreFlow.StoreSelection_FlyIIn.mvc$controller.OnKeyUp_Input.EnterKeyPressedJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
if(event.keyCode==13){
    var inputElem = document.getElementById($parameters.InputId);
    if(inputElem)
        inputElem.blur();
        
    $actions.OnClick_SearchStore();

}
};
});


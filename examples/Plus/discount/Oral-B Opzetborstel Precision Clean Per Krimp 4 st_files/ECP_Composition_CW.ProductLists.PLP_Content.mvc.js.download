define("ECP_Composition_CW.ProductLists.PLP_Content.mvc$controller.JS_InitSponsoredProductsViewport.InitSponsoredProductsViewportJS", [], function () {
return function ($actions, $roles, $public) {
var callback = (entries, observer) => {
  entries.forEach(entry => {
        if(entry.isIntersecting) {
            $actions.ElementVisibleViewport(parseInt(entry.target.getAttribute('product-index')));
        }
  })
};

var observer = new IntersectionObserver(callback, {
  threshold: [0.5]
});

document.querySelectorAll('.gtm-plp-ad').forEach((el)=> {
    if (el.dataset.libraryNameObserverType === 'true') 
    {
        //If the element is already being observed there's no need to be reobserved again. This is to protect form infinite scroll duplicates
    } else {
        observer.observe(el);
        el.dataset.libraryNameObserverType = 'true';
    }
});
};
});

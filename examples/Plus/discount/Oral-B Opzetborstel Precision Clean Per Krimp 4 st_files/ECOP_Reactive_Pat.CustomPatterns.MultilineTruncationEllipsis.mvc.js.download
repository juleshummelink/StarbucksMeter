define("ECOP_Reactive_Pat.CustomPatterns.MultilineTruncationEllipsis.mvc$controller.ComputeNumLinesAndHeight.SetInitialParametersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
document.getElementById($parameters.TruncationTextId).style.webkitLineClamp = $parameters.NumOfVisibleLines;
document.getElementById($parameters.TruncationBoxId).style.height = $parameters.InitialHeight;
};
});
define("ECOP_Reactive_Pat.CustomPatterns.MultilineTruncationEllipsis.mvc$controller.ComputeNumLinesAndHeight.GetLineHeightJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const parentElement = document.getElementById($parameters.TruncationTextId);
const el = parentElement.firstChild;
const divHeight = el.offsetHeight
const lineHeight = parseInt(window.getComputedStyle(el, null).getPropertyValue("line-height").replace('px', ''));
const lines = parseInt(divHeight / lineHeight);

if(lines <= $parameters.NumVisibleLines) {
    $parameters.HideLink_Out = true;
    $parameters.NumVisibleLines = lines;
}
    
const lns = $parameters.HideLink || lines === 0 ? 0 : 1;
$parameters.InitialHeight = (($parameters.NumVisibleLines + lns) * lineHeight) + "px"
$parameters.ElemText = el.textContent;
};
});
define("ECOP_Reactive_Pat.CustomPatterns.MultilineTruncationEllipsis.mvc$controller.OnToggle.CollapseJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let animationSpeed = getComputedStyle(document.documentElement).getPropertyValue('--multiline-animation-speed-'+ $parameters.Animation);
let timeout = animationSpeed ? animationSpeed.replace('ms','') : 0;


setTimeout(() => {
  document.getElementById($parameters.TruncationTextId).style.webkitLineClamp = $parameters.NumOfLines;
}, parseFloat(timeout));

document.getElementById($parameters.TruncationBoxId).style.height = $parameters.InitialHeight;
document.getElementById($parameters.TruncationBoxId).classList.remove('open');
document.getElementById($parameters.TruncationBoxId).classList.add('closed');

};
});
define("ECOP_Reactive_Pat.CustomPatterns.MultilineTruncationEllipsis.mvc$controller.OnToggle.ExpandJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
document.getElementById($parameters.TruncationTextId).style.webkitLineClamp = 9999;

setTimeout(() => {
    document.getElementById($parameters.TruncationBoxId).style.height = document.getElementById($parameters.TruncationTextWrapperId).offsetHeight + 'px';
    document.getElementById($parameters.TruncationBoxId).classList.remove('closed');
    document.getElementById($parameters.TruncationBoxId).classList.add('open');
}, 100);



};
});


define("CMS_Monolith_CW.CMS_OverviewPage_RCW.Overviewpage_TF.mvc$controller.ComponentDidMount.ScrollIntoViewJS", [], function () {
return function ($actions, $roles, $public) {
let fragmentIdentifier = window.location.hash;
let screenContainer = document.querySelector(".screen-container");

if (fragmentIdentifier && screenContainer) {
    let targetElement = document.querySelector('[name="' + fragmentIdentifier.slice(1) + '"]');
    if (targetElement) {
        let headerOffset = document.querySelector(".header-content").offsetHeight;
        let elementPosition = targetElement.getBoundingClientRect().top;
        let offsetPosition = elementPosition - headerOffset - 25;
        screenContainer.scrollTo(0, offsetPosition);
    }
}

};

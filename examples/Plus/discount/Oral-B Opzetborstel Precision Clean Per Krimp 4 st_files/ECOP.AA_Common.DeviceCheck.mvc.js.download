define("ECOP.AA_Common.DeviceCheck.mvc$controller.SetDevice_Tablet.SetDevice_TabletJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
requestAnimationFrame(() => {
    if($parameters.query_media_Obj.query_tablet.matches)
        $actions.SetDeviceClass("tablet");
});
};
});
define("ECOP.AA_Common.DeviceCheck.mvc$controller.OnDestroy.RemoveDeviceMediaQueryListenersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
$parameters.query_media.query_phone.removeEventListener('change', $actions.SetDevice_Phone);

$parameters.query_media.query_tablet.removeEventListener('change', $actions.SetDevice_Tablet);

$parameters.query_media.query_desktop.removeEventListener('change', $actions.SetDevice_Desktop);
};
});
define("ECOP.AA_Common.DeviceCheck.mvc$controller.SetDevice_Phone.SetDevice_PhoneJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
requestAnimationFrame(() => {
    if($parameters.query_media_Obj.query_phone.matches)
        $actions.SetDeviceClass("phone");
});
};
});
define("ECOP.AA_Common.DeviceCheck.mvc$controller.OnInitialize.DetectDeviceChangeOnResizeJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
$parameters.query_media = {
    query_phone: matchMedia('(max-width: 767px)'),
    query_tablet: matchMedia('(min-width: 768px) and (max-width:1024px)'),
    query_desktop: matchMedia('(min-width: 1025px)')
}

if($parameters.query_media.query_phone.matches)
    $actions.SetDeviceClass("phone");
if($parameters.query_media.query_tablet.matches)
    $actions.SetDeviceClass("tablet");
if($parameters.query_media.query_desktop.matches)
    $actions.SetDeviceClass("desktop");


$parameters.query_media.query_phone.addEventListener('change', $actions.SetDevice_Phone);

$parameters.query_media.query_tablet.addEventListener('change', $actions.SetDevice_Tablet);

$parameters.query_media.query_desktop.addEventListener('change', $actions.SetDevice_Desktop);


};
});
define("ECOP.AA_Common.DeviceCheck.mvc$controller.SetDevice_Desktop.SetDevice_DesktopJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
requestAnimationFrame(() => {
    if($parameters.query_media_Obj.query_desktop.matches)
        $actions.SetDeviceClass("desktop");
});
};
});
define("ECOP.AA_Common.DeviceCheck.mvc$controller.SetDeviceClass.SetDeviceClassOnBodyJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const deviceList = ["phone", "tablet", "desktop"];
const body = document.body;

switch($parameters.DeviceName) {
    case (deviceList[0]):
        body.classList.remove(deviceList[1]);
        body.classList.remove(deviceList[2]);
        if(!body.classList.contains(deviceList[0]))
            body.classList.add(deviceList[0]);
        break;
    case (deviceList[1]):
        body.classList.remove(deviceList[0]);
        body.classList.remove(deviceList[2]);
        if(!body.classList.contains(deviceList[1]))
            body.classList.add(deviceList[1]);
        break;
    case (deviceList[2]):  
        body.classList.remove(deviceList[0]);
        body.classList.remove(deviceList[1]);
        if(!body.classList.contains(deviceList[2]))
            body.classList.add(deviceList[2]);
        break;
}
};
});


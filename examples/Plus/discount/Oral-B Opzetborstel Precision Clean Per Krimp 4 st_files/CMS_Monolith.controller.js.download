return function ($parameters, $actions, $roles, $public) {
if(globalThis && globalThis.cachedStaticImgs)
{
    var imgObj = globalThis.cachedStaticImgs.find(item => {
        return item.Slug == $parameters.ImgSlug;
    });

    if(imgObj && imgObj.URL) {
        $parameters.URL = imgObj.URL;
    }
    else{
        console.log('Static image not found on localstorage for Slug: ' + $parameters.ImgSlug);
    }
}
else{
    console.log('GetStaticImage: Static images cached not initialized.');
}
};
});


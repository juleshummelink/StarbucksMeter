    $parameters.Include = 10;
}

var query = {content_type: $parameters.ContentTypeId,include: $parameters.Include}

if($parameters.PageSlugFieldValue !== '') {
    query['fields.slug'] = $parameters.PageSlugFieldValue
}

if($parameters.SlugParamFieldValue !== '') {
    query['fields.slugParam'] = $parameters.SlugParamFieldValue
}

if($parameters.SecondarySlugParamFieldValue !== '') {

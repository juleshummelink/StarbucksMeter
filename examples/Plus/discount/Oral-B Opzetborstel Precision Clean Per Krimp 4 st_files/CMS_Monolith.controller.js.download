return function ($parameters, $actions, $roles, $public) {
return new Promise(function ($resolve, $reject) {
let replacerFunction = $parameters.ReplacerFunction;
var contentfulObj = $parameters.ContentfulClientInstance;
//Note: include: 10 is the limit. i.e. you can't go deeper than 10 levels!

contentfulObj.getEntries({
    'sys.id': $parameters.EntryId,
    include: $parameters.Include,
    limit: 1
}).then(function(entries) {
    
    if(entries.total === 0){
        $parameters.JSONResponse = '';
    }else{
        var entryItem = entries.items[0]; //Always returns 1 item (limit: 1), so target first element of items array 
        $parameters.JSONResponse = JSON.stringify(entryItem, replacerFunction());
    }
    $resolve();

}).catch(function(error) {
    $parameters.ErrorMessage = error.message;
    $resolve();
});
});
};
});


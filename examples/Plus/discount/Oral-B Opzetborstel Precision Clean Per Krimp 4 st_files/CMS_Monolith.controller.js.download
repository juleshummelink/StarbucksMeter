define("CMS_Monolith.controller$AnchorLink_ScrollTo.NavigateToAnchorLinkJS", [], function () {
return function ($actions, $roles, $public) {
    // The function to execute when mutations are observed
    const callback = function(mutationsList, observer) {
        if(window.location.hash === '') return;
        let hashValue = window.location.hash.substr(1);
        for(let mutation of mutationsList) {
            // If the addedNodes property has one or more nodes
            if (mutation.addedNodes.length) {
                for(let node of mutation.addedNodes) {
                    // If the node's inner HTML attribute exists and contains the hash value of the URL
                    // IMPORTANT: If we search exactly for the name property in the H2 tag where the hashValue is, then the code is not build futureproof because a change in the div hierarchy in the component is sufficient for this code to stop working
                    if (node.innerHTML && node.innerHTML.includes(hashValue)){
                        
                        let anchor = document.getElementsByName(hashValue)[0];
                        if (anchor === undefined) return;
                        setTimeout(()=> {
                            $actions.AnchorLink_ScrollToElement(anchor, true);
                        }, 100)                        
                        observer.disconnect();    
                    }
                }
            }
        }
    };

    // Create a new instance of `MutationObserver` named `observer`,
    // passing it the callback function
    const observer = new MutationObserver(callback);

    // Start observing the document with the configured parameters
    observer.observe(document, { childList: true, subtree: true });



};
});


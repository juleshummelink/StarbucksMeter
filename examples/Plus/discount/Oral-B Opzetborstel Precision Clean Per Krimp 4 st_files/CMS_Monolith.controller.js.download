define("CMS_Monolith.controller$JSON_StringifySafeReplacerFunction.JSONStringifySafeJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
/* This action prevents circular references - A top level page including an element (e.g. banner) that references the top level page, is a circular reference
For each internal link (or referenced recipe in a recipe component) the action creates a lighweight version of the object containing only the essential properties
Supports:
    -Internal link entries referencing pages (1-to-1 relation)
    -Recipe component entries referencing recipes (1-to-many relation)
    -Having multiple fields in the same entry that lead to circualr refs is supported.
    -Using different naming (accross contentTypes) for the FieldId's for the reference field (to an internal link or recipe Component) is supported 
    -All non-reference fields are copied to the lightweight version by default, exceptions are hardcoded

The function should be used when stringyfing the response from contentful*/
$parameters.ReplacerFunction = function replacer() {
    return function(parentKey, parentValue) {
        if (parentValue === null || typeof parentValue !== "object") {
            return parentValue;
        }
        Object.keys(parentValue).forEach(function(nestedKey, nestedValue) {
            //We don't need to check arrays. Note: items of arrays will be targetted individually when using Json.stringify(obj, replacer())
            if (nestedKey === null || Array.isArray(parentValue[nestedKey])) {
                return parentValue
            }
            //The referenced content might be needed to parse the URL (Slug and/or URL parameters =SKU number for example)
            //Check if referenced content is in the JSON. If max returned levels is 10, than it could happen that the referecned content is on level 11, and the field property won't be there.
            if (checkNestedKey(parentValue, nestedKey, 'fields', 'referencedContent', 'fields')) {
                if (parentValue[nestedKey].sys.contentType.sys.id !== 'internalLink') {
                    return;
                }
                let shallowCopy = {};
                let originalFields = {};
                shallowCopy = Object.assign({}, parentValue[nestedKey].fields.referencedContent);
                Object.keys(shallowCopy.fields).forEach(function(shallowKey, shallowValue) {
                    if (typeof shallowCopy.fields[shallowKey] === 'object' || shallowCopy.fields[shallowKey] === null) {
                        return;
                    }
                    originalFields[shallowKey] = shallowCopy.fields[shallowKey]
                })
                let lightweightObj = {
                    sys: {
                        contentType: shallowCopy.sys.contentType
                    },
                    fields: originalFields //may contain slug, title, productCeNumber ... or anything else needed to parse the URL later on
                };
                //Add tags (for blogpages), so we can inherit them if needed
                if (checkNestedKey(shallowCopy, 'fields', 'tags')) {
                    let originalTags = shallowCopy.fields.tags;
                    lightweightObj.fields.tags = originalTags
                }
                //Add image (for blogpages), so we can inherit them if needed
                if (checkNestedKey(shallowCopy, 'fields', 'image')) {
                    let originalImage = shallowCopy.fields.image;
                    lightweightObj.fields.image = originalImage
                }
                //Add thumbnail image (for blogpages), so we can inherit them if needed
                if (checkNestedKey(shallowCopy, 'fields', 'thumbnailImage')) {
                    let originalThumbnailImage = shallowCopy.fields.thumbnailImage;
                    lightweightObj.fields.thumbnailImage = originalThumbnailImage
                }
                //Add image (for page content type), so we can inherit them if needed
                if (checkNestedKey(shallowCopy, 'fields', 'content', 'fields', 'image')) {
                    let pageImage = shallowCopy.fields.content.fields.image;
                    lightweightObj.fields.image = pageImage
                }
                //Add thumbnail image (for page content type), so we can inherit them if needed
                if (checkNestedKey(shallowCopy, 'fields', 'content', 'fields', 'thumbnailImage')) {
                    let pageThumbnailImage = shallowCopy.fields.content.fields.thumbnailImage;
                    lightweightObj.fields.thumbnailImage = pageThumbnailImage
                }
                parentValue[nestedKey].fields.referencedContent = lightweightObj;
            } else if (checkNestedKey(parentValue, nestedKey, 'fields', 'recipes', 'fields')) {
                //reference to recipe component. recipes inside recipe component are a one-to-many relation (array)
                if (parentValue[nestedKey].sys.contentType.sys.id !== 'recipeComponent') {
                    return;
                }
                let shallowCopyArr = [];
                let originalFields = {};
                let originalEntryArray = [];
                let lightweightObjInArray = {};
                shallowCopyArr = Array.from(parentValue[nestedKey].fields.recipes);
                //recipes field is an Array of recipe entries/objects (one-to-many relation)
                shallowCopyArr.forEach(function(entryInArray, index) {
                    originalFields = {};
                    Object.keys(entryInArray.fields).forEach(function(shallowKey, shallowValue) {
                        if (typeof entryInArray.fields[shallowKey] === 'object' || entryInArray.fields[shallowKey] === null) {
                            return
                        }
                        originalFields[shallowKey] = entryInArray.fields[shallowKey]
                    })
                    lightweightObjInArray = {
                        sys: {
                            contentType: entryInArray.sys.contentType
                        },
                        fields: originalFields //may contain slug, title, productCeNumber ... or anything else needed to parse the URL later on
                    };

                    //Add images (for recipes), so we can inherit them if in recipeItems
                    if (checkNestedKey(entryInArray, 'fields', 'images')) {
                        let originalImage = entryInArray.fields.images;
                        lightweightObjInArray.fields.images = originalImage
                    }

                    originalEntryArray.push(lightweightObjInArray);
                });
                parentValue[nestedKey].fields.recipes = originalEntryArray;    
            } else {
                return
            }
        });
        return parentValue;
    };
    //Nested function that can check existence of nested key in object property.
    function checkNestedKey(obj /*, level1, level2, ... levelN*/ ) {
        let args = Array.prototype.slice.call(arguments, 1);
        for (var i = 0; i < args.length; i++) {
            if (!obj || !obj.hasOwnProperty(args[i])) {
                return false;
            } else if (Array.isArray(obj[args[i]])) {
                obj = obj[args[i]][0];
            } else {
                obj = obj[args[i]];
            }
        }
        return true;
    }
};
};
});


define("CMS_Monolith.controller$Entries_GetByQuery_V2.GetEntriesJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
return new Promise(function ($resolve, $reject) {
"use strict";
let replacerFunction = $parameters.ReplacerFunction;

let queryObj = JSON.parse($parameters.Query)
let customQueryObj = {};

if($parameters.CustomQuerySerializedString !== ""){
   
    var parsedQueryObj = JSON.parse($parameters.CustomQuerySerializedString);

    for (let i = 0; i < parsedQueryObj.length; i++) {
        let queryKey = parsedQueryObj[i].Key;
        let queryVal = parsedQueryObj[i].Value
        try{
            if(!queryKey || !queryVal){
                throw new Error('Invalid custom query key/value');
            }
        } catch(e) {
            $parameters.ErrorMessage = e.message;
            $resolve();
        }
        customQueryObj[queryKey] = parsedQueryObj[i].Value
    }
    
}

if(queryObj.select && queryObj.select.length === 0){
    delete queryObj.select;
}

//This is incorrectly considered a syntax error by OutSystems, and consequently breaks solution publishing.
//const query = {...queryObj, ...customQueryObj}
const query = {};
Object.assign(query, queryObj, customQueryObj);

var contentfulObj = $parameters.ContentfulClientInstance;
contentfulObj.getEntries(query).then(function(entries) {

    if(entries.total === 0){
        $parameters.JSONResponse = '';
    }else if(entries.total === 1){
        $parameters.JSONResponse = JSON.stringify(entries.items[0], replacerFunction()); 
    }else{
        $parameters.JSONResponse = JSON.stringify(entries.items, replacerFunction());
    }

    $parameters.TotalResults = entries.total;
    $resolve();
}).catch(function(error) {
    $parameters.ErrorMessage = error.message;
    $resolve();
});
});
};
});


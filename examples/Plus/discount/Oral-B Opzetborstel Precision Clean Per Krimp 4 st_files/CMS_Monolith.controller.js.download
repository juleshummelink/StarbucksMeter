define("CMS_Monolith.controller$GetRichTextParser.ParserJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
$parameters.RichTextParser = function(array) {
    //Array to collect the parsed RichText nodes
    const hyperLinkRenderOptions = {

        renderNode: {
            'hyperlink': function(node, next) {
                //if the hyperlink is an anchor link, we just want to build the hyperlink as is, without any protocol
                if(!node.data.uri.startsWith('#')){
                    var securedProtocol = 'https://'
                    var normalProtocol = 'http://'
                    if(node.data.uri.indexOf(securedProtocol) === -1 && node.data.uri.indexOf(normalProtocol) === -1){
                        node.data.uri = securedProtocol + node.data.uri
                    }    
                }
                let isSameHost = $actions.CheckIfValidURL(node.data.uri).IsURL ? new URL(node.data.uri).host === window.location.host : false;
                var url = "<a href=" + node.data.uri;
                if (node.data.altText) {
                    url = url + " alt='" + node.data.altText + "'";
                }

                if (node.data.contentTypeId !== 'internalLink' && !isSameHost) {
                    url = url + " target='_blank'>";                
                } else {
                    url = url + ">";
                }

                if (node.content[0] && node.content[0].value !== '') {
                    url = url + node.content[0].value + "</a>";
                } else {
                    url = url + node.data.uri + "</a>";
                }

                return url;
            },
            'heading-2': function(node) {
                return '<h2 name=' + $actions.Text_Slugify(node.content[0].value).SlugifiedText + '>' + node.content[0].value + '</h2>';
            },
            'heading-3': function(node) {
                return '<h3 name=' + $actions.Text_Slugify(node.content[0].value).SlugifiedText + '>' + node.content[0].value + '</h3>';
            },
            'table': (node, next) => {
                return '<table class="cf-rich-text-table">' + next(node.content) + '</table>';
            }
        }
    }

    var parsedItems = []; //Array to collect the parsed RichText nodes
    var item = {
        html: '',
        entry: {
            contentTypeId: '',
            entryJSON: '',
            isInline: false
        }
    }; //Format of a parsed richtext node in an Outsystems readable format
    for (var i = 0; i < array.length; i++) {
        var nodeType = array[i].nodeType;

        //Finding inline embedded entries. Always within a paragraph node, could be alongside other paragraph nodes e.g. text/hyperlinks/bold text...
        var inlineEntryInNode = array[i].content.filter(function(node) {
            return node.nodeType === 'embedded-entry-inline' || node.nodeType === 'entry-hyperlink'
        }).length > 0

        //skip last empty paragraph
        if (nodeType === "paragraph" && inlineEntryInNode) {

            var contentArray = array[i].content;
            var textContentArray = [];
            for (var j = 0; j < contentArray.length; j++) {
                var childNodeType = contentArray[j].nodeType;
                var nextNodeType = (contentArray[j + 1] ? contentArray[j + 1].nodeType : 'undefined');
                var thirdNodeType = (contentArray[j + 2] ? contentArray[j + 2].nodeType : 'undefined');
                if (childNodeType === 'entry-hyperlink') {

                    var contentTypeId = contentArray[j].data.target.sys.contentType.sys.id
                    //simulate a hyperlink node
                    var hyperlinkNode = {
                        "data": {
                            "uri": '',
                            "altText": '',
                            "contentTypeId": contentTypeId
                        },
                        "content": [{
                            "data": {},
                            "marks": [],
                            "value": contentArray[j].content[0].value,
                            "nodeType": "text"
                        }],
                        "nodeType": "hyperlink"
                    }

                    if (contentTypeId === 'pdf') {
                        hyperlinkNode.data.uri = contentArray[j].data.target.fields.pdfAsset.fields.file.url
                        hyperlinkNode.data.altText = contentArray[j].data.target.fields.altText
                    } else if (contentTypeId === 'internalLink') {
                        hyperlinkNode.data.uri = contentArray[j].data.target.resolvedLink.url
                        hyperlinkNode.data.altText = contentArray[j].data.target.resolvedLink.title
                    }
                    textContentArray.push(hyperlinkNode);
                    continue;

                } else if (childNodeType === 'embedded-entry-inline') {
                    if(!contentArray[j].data.target.sys.hasOwnProperty('contentType')) { 
                        //if there is an embedded entry inline in Draft status, we do not process it
                        continue;
                    } else {
                        item = {
                            html: '',
                            entry: {
                                contentTypeId: contentArray[j].data.target.sys.contentType.sys.id,
                                entryJSON: JSON.stringify(contentArray[j].data.target),
                                isInline: true
                            }
                        };
                    }

                    //Delete empty text node inbetween 2 inline entries, skip it. Added by default..
                    if (nextNodeType === 'text' && contentArray[j + 1].value === '' && thirdNodeType === 'embedded-entry-inline') {
                        j = j + 1
                    }
                } else if (childNodeType === 'text' && (nextNodeType === 'embedded-entry-inline' || nextNodeType === 'undefined')) {

                    textContentArray.push(contentArray[j]);
                    var richTextnode = {
                        content: [{
                            content: textContentArray,
                            data: {},
                            nodeType: "paragraph"
                        }],
                        data: {},
                        nodeType: "document"
                    }; //Simulate a parent richText node.
                    var nodeHtml = documentToHtmlString(richTextnode, hyperLinkRenderOptions);
                    item = {
                        html: nodeHtml,
                        entry: {
                            contentTypeId: '',
                            entryJSON: '',
                            isInline: false
                        }
                    };
                    textContentArray = []; // reset array
                } else if (i === array.length - 1 && nodeType === "paragraph" && array[i].content.length === 1 && array[i].content[0].value === '') {
                    continue
                } else {
                    textContentArray.push(contentArray[j]);
                    continue; //go to next item in this nested for loop, without pushing the parsedItems
                }
                parsedItems.push(item);
            }
            continue; //we already pushed the child items in the nested for-loop. So we can go to next item in parent loop
        } else if ((nodeType === "embedded-entry-block" || nodeType === "embedded-asset-block") && !array[i].data.target.sys.hasOwnProperty('contentType')) { 
            //if there is an embedded asset or entry in Draft status, we do not process it
            continue;
        } else if (nodeType === "embedded-entry-block") {
            var entryObject = JSON.stringify(array[i].data.target);
            item = {
                html: '',
                entry: {
                    contentTypeId: array[i].data.target.sys.contentType.sys.id,
                    entryJSON: entryObject,
                    isInline: false
                }
            };
        } else if (nodeType === "embedded-asset-block") {
            var entryObject = JSON.stringify(array[i].data.target);
            item = {
                html: '',
                entry: {
                    contentTypeId: 'Asset',
                    entryJSON: entryObject,
                    isInline: false
                }
            };
        } else {
            //RichText without embedded assets or entries
            var nodeHtml
            if (array[i].content.length === 1 && array[i].content[0].value === '') {
                nodeHtml = '<p></p>'; //just a linebreak in richText editor. 
            } else {
                //Simulate a parent richText node, since the documentToHtmlString expects a richText node.
                var richTextnode = {
                    content: [array[i]],
                    data: {},
                    nodeType: "document"
                };
                nodeHtml = documentToHtmlString(richTextnode, hyperLinkRenderOptions);
            }
            item = {
                html: nodeHtml,
                entry: {
                    contentTypeId: '',
                    entryJSON: '',
                    isInline: false
                }
            };
        }
        parsedItems.push(item);
    }
    return parsedItems
}
};
});

define("CMS_Monolith.controller$GetStaticImage", ["exports", "OutSystems/ClientRuntime/Main", "CMS_Monolith.model", "CMS_Monolith.controller", "CMS_Monolith.controller$GetStaticImage.GetImageUrlFromStaticImgJsonJS", "CMS_Monolith.controller$ContentfulImageOptimization", "CMS_Monolith.controller$ImageUtils_GetCDNImgFormat"], function (exports, OutSystems, CMS_MonolithModel, CMS_MonolithController, CMS_Monolith_controller_GetStaticImage_GetImageUrlFromStaticImgJsonJS) {

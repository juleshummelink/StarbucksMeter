define("CMS_Monolith.controller$IsOpenInNewTab.CheckIsExternalURLJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
var url;

try{
    url = $actions.IsURLRelativePath2($parameters.URL).IsRelativePath ? new URL($parameters.URL, window.location.protocol + '//' + window.location.host) : new URL($parameters.URL);
    if(window.location.host !== url.host){
        $parameters.IsExternal = true;
    }else{
        $parameters.IsExternal = false;
    }

}catch(error){
    $parameters.ErrorMessage = "URL is invalid: " + $parameters.URL;
}


//note: host attribute includes subdomain of url
};
});


return PL_MT_Logs_BLController.default.createGlobalLog$Action(CMS_MonolithModel.staticEntities.globalType.cartConnectAPI, "GetProductsByRecipeSlug", CMS_MonolithModel.staticEntities.applications.eCOP, ("No data retrieved  from CartConnect API with recipeid=" + vars.value.recipeIdVar), "", false, callContext);
}


return function ($parameters, $actions, $roles, $public) {
let query = '';
let screenCont

if($parameters.IsPhone){
    query = query.concat('.phone .screen-container, ');
}

if($parameters.IsTablet){
    query = query.concat('.tablet .screen-container, ');
}

if($parameters.IsDesktop){
    query = query.concat('.desktop .screen-container, ');
}

if(query.length > 2){
    query = query.slice(0,-2);
    screenCont = document.querySelector(query);
}

if(screenCont){
    screenCont.scrollTo({top: 0, behavior: 'smooth'});
}
};
});


define("CMS_Monolith.controller$Index_UpdateIndexLinksToAnchor.UpdateLinksJS", [], function () {
return function ($actions, $roles, $public) {
setTimeout(function() {
    let links = document.querySelectorAll(".cf-side-menu-page__content a");
    links.forEach(element => {
        let url = new URL(element.href);
        if (url.hash !== "") {
            if (url.pathname === window.location.pathname) {
                //anchor link
                let scrollElement = document.getElementsByName(url.hash.substr(1))[0];
                if (scrollElement !== undefined) {
                    element.setAttribute('target', '_self'); // make sure the link does not open a new tab
                    element.addEventListener('click', (event) => {
                        event.preventDefault();
                        $actions.AnchorLink_ScrollToElement(scrollElement);
                    })
                }
            }
        }
    });
}, 600);
};
});


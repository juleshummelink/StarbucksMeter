define("CMS_Monolith.controller$Banner_HandleFocus.SetRemoveFocusJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const activeElement = document.activeElement;

if (activeElement) {
    const childLinks = activeElement.querySelectorAll(
        'a.cf-link-wrapper-web.text-arrow-wrapper span, ' +
        'a.cf-link-wrapper-web .text-arrow-wrapper.cf-small-banner__cta span, ' +
        'a .text-arrow-wrapper.cf-promotional-product__cta-text span, ' +
        'a .text-arrow-wrapper.cf-big-banner__cta-text span'
    );

    if (childLinks.length > 0) {
        childLinks.forEach((link, i) => {
            if (typeof $parameters !== 'undefined' && $parameters.IsSetFocus) {
                link.classList.add('banner-link-focus');
            } else {
                link.classList.remove('banner-link-focus');
            }
        });
    }
}

};
});


        $parameters.JSONResponse = '';
    }else if(entries.total === 1){
        $parameters.JSONResponse = JSON.stringify(entries.items[0], stringifyReplacerFunction()); 
    }else{
        $parameters.JSONResponse = JSON.stringify(entries.items, stringifyReplacerFunction());
    }
    $resolve();

}).catch(function(error) {
    $parameters.ErrorMessage = error.message;
    $resolve();
});
});
};

define("CMS_Monolith.controller$AnchorLink_ScrollToElement.ScrolToElementJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let anchor = $parameters.Element
let header = document.querySelector('.header');
let layout = document.querySelector('.layout');
let isFixed = layout.classList.contains('fixed-header');
let isHideMenu = layout.classList.contains('hide-menu');
let isPhone = document.getElementsByTagName('body')[0].classList.contains('phone');
let positionOffset = isFixed ? (isPhone? 0 : 47) : (isPhone ? 100 : 85);

// pull the target up from its original position, pulling it the header amount so in the end it won't be covered by the header
// it removes the height from whatever offset you might want to remove from the top
if (isFixed && isHideMenu) {
    anchor.style.transform = 'translateY(' + (-header.offsetHeight + (-positionOffset)) + 'px)';
} else if (isFixed){
    anchor.style.transform = 'translateY(' + (-header.offsetHeight + positionOffset) + 'px)';
} else {
    anchor.style.transform = 'translateY('+ -positionOffset +'px)';
}

anchor.style.display = 'block';

let timeout = $parameters.IsURLAnchor ? 500 : 0;
// timeout needs to be added as a hack for the scrollIntoView to act
setTimeout(function() {
    anchor.scrollIntoView({
        behavior: 'smooth',
        block: 'start'
    });
    // reset to the original position
    anchor.style.transform = '';
    anchor.style.display = '';
}, timeout);
};
});


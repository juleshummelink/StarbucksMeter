define("CMS_Monolith.controller$URL_GenerateURLForLinkEntry_V4.JSONsetExternalLinkObjByPathJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
try{
var parentObj = JSON.parse($parameters.ParentEntry);
var pathArray = JSON.parse($parameters.ExternalLinkPathArrayString);

    for (var i = 0; i < pathArray.length; i++) {
        
        var stringPath = pathArray[i];
        
        var linkObj = {title: '', url: ''};
        var childObj = $actions.ResolvePath_GetChild(parentObj,stringPath).ChildObject;
        
        linkObj.title = childObj.fields.title;
        linkObj.url = childObj.fields.externalUrl;

        stringPath = stringPath + "['resolvedLink']";

        parentObj = $actions.ParentObject_SetPathObject(parentObj,stringPath,linkObj).NewParentObject;
        
    }

    $parameters.NewParentEntry = JSON.stringify(parentObj);

}catch(error){
    $parameters.ErrorMessage = error.message;
}
};
});
define("CMS_Monolith.controller$URL_GenerateURLForLinkEntry_V4.JSONsetInternalLinkObjByPathJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
try{
var parentObj = JSON.parse($parameters.ParentEntry);
var ProcessedLinks = JSON.parse($parameters.ProcessedInternalLinks);

    for (var i = 0; i < ProcessedLinks.length; i++) {

        var stringPath = ProcessedLinks[i].path;
        stringPath = stringPath + "['resolvedLink']";
        var linkObj = {title: '', url: ''};
        
        linkObj.title =  ProcessedLinks[i].title;
        linkObj.url =  ProcessedLinks[i].url;
        
        parentObj = $actions.ParentObject_SetPathObject(parentObj,stringPath,linkObj).NewParentObject;
        
    }

    $parameters.NewParentEntry = JSON.stringify(parentObj);

}catch(error){
    $parameters.ErrorMessage = error.message;
}
};
});
define("CMS_Monolith.controller$URL_GenerateURLForLinkEntry_V4.BuildInputForServerActionJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
try{
    var allowedLinkTypes = ['page', 'blogPage', 'overviewPageTheme', $parameters.ProductDetailPageContentTypeId, $parameters.ProductListingPageContentTypeId, 'promotionDetailPage', 'dashboard', $parameters.RecipeContentTypeId, 'sideMenuPage', 'pressRelease', 'newsArticle', 'folderPage', 'masterBlogPage'];
    var parentObj = JSON.parse($parameters.ParentEntry);
    var pathArray = JSON.parse($parameters.InternallLinkPathArrayString);
    var internalLinkList = [];
    
    for (var i = 0; i < pathArray.length; i++) {
        
        var stringPath = pathArray[i];
        var referencedLinkObj = $actions.ResolvePath_GetChild(parentObj,stringPath).ChildObject;

         //Check if the content of the internalLink is resolved. Suppose you only ahve 6 levels resolved, the content could be on level 7, which is not present on the parentObject... If content is not availeble than the fields key is not in the response of the entry
        var checkInternalLink = "";
        var checkFieldsKey = ""
        try{
            checkFieldsKey = referencedLinkObj.fields.referencedContent.fields;
            checkInternalLink = referencedLinkObj.fields.referencedContent.sys.contentType.sys.id;
        }catch(e) {
            if(e.name !== 'TypeError') {
                throw e;
            }
        }
        
        if(checkInternalLink === ''){
            continue
        }

        var internalLinkItem = {title: '', linkEntryJson: '', path: '', slug: '', isStatic: false, contentTypeId: '', dynamicAttr: ''};
        
        internalLinkItem.title = referencedLinkObj.fields.title;
        internalLinkItem.linkEntryJson = JSON.stringify(referencedLinkObj.fields); 
        internalLinkItem.path = stringPath;
        internalLinkItem.contentTypeId = checkInternalLink;
       
        if(allowedLinkTypes.includes(internalLinkItem.contentTypeId)){
             internalLinkItem.isStatic = internalLinkItem.contentTypeId == 'page';
             internalLinkItem.slug = referencedLinkObj.fields.referencedContent.fields.slug;
             if(internalLinkItem.contentTypeId == $parameters.ProductListingPageContentTypeId) {
                internalLinkItem.dynamicAttr = referencedLinkObj.fields.referencedContent.fields.category;
             } else {
                if(internalLinkItem.contentTypeId == $parameters.RecipeContentTypeId) {
                    internalLinkItem.dynamicAttr = referencedLinkObj.fields.referencedContent.fields.recipeId;
                } else {
                    if(internalLinkItem.contentTypeId == $parameters.ProductDetailPageContentTypeId) {
                        internalLinkItem.dynamicAttr = referencedLinkObj.fields.referencedContent.fields.productCeNumber;
                    }
                }
             } 
        }
        
        internalLinkList.push(internalLinkItem);
        
    }

    $parameters.InternalLinksArrayString = JSON.stringify(internalLinkList);

}catch(error){
    $parameters.ErrorMessage = error.message;
}
};
});


define("ECOP_Base_RPat.CustomPatterns.OnHoverTooltip.mvc$controller.OnReady.InitializeTooltipJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
const container = document.querySelector("." + $parameters.HoverContainer);
const tooltip = document.getElementById($parameters.TooltipContentId);

tooltip.style.width = $parameters.TooltipWidth + "px";

var isTouchScreen = false;

//Set initial styles
tooltip.style.display = "none";
tooltip.style.position = "fixed";
tooltip.style.zIndex = "999";

//Set event listener
if($parameters.OnClickOnly){
    container.addEventListener("click", $actions.handler_OnMove);
} else {
    container.addEventListener("mousemove", $actions.handler_OnMove);
    container.addEventListener("mouseleave", $actions.handler_OnMove);
}

document.addEventListener("touchstart", $actions.handler_OnScroll);
document.addEventListener('wheel', $actions.handler_OnScroll);


$parameters.ContainerObj = container;
$parameters.TooltipObj = tooltip;
};
});
define("ECOP_Base_RPat.CustomPatterns.OnHoverTooltip.mvc$controller.handler_OnScroll.HideTooltipJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
$parameters.TooltipObj.style.display = "none";
};
});
define("ECOP_Base_RPat.CustomPatterns.OnHoverTooltip.mvc$controller.OnDestroy.RemoveEventListenersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
$parameters.ContainerObj.removeEventListener("mousemove", $actions.handler_OnMove);
$parameters.ContainerObj.removeEventListener("mouseleave",$actions.handler_OnMove);
$parameters.ContainerObj.removeEventListener("click", $actions.handler_OnMove);
document.removeEventListener("touchstart", $actions.handler_OnScroll);
document.removeEventListener('wheel', $actions.handler_OnScroll);
};
});
define("ECOP_Base_RPat.CustomPatterns.OnHoverTooltip.mvc$controller.handler_OnMove.MouseMoveHandlerJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let cursorX = window.event.clientX;
let cursorY = window.event.clientY;
let rect = window.event.currentTarget.getBoundingClientRect();
let relativeCursorX = window.event.clientX - rect.left;
let relativeCursorY = window.event.clientY - rect.top;
let viewport_width = document.documentElement.clientWidth;
let viewport_height = document.documentElement.clientHeight;
let closestElement = "";

if($parameters.HoveredElementsClass !== "") { 
    closestElement = window.event.target.closest("." + $parameters.HoveredElementsClass);
}

if(closestElement || $parameters.HoveredElementsClass == ""){

    //Makes tooltip visible
    $parameters.TooltipObj.style.display = "block";

    let tooltipHeight = $parameters.TooltipObj.offsetHeight;
    let tooltipWidth = $parameters.TooltipObj.offsetWidth;
    
    //Set X axis coordinates
    if(((cursorX + $parameters.OffsetX + tooltipWidth) <= viewport_width) && cursorX + $parameters.OffsetX >= 0 ) {
        if($parameters.PositionRelativeToParent) {
            $parameters.TooltipObj.style.left = relativeCursorX + $parameters.OffsetX + "px";
        }else {
            ($parameters.TooltipObj.style.left = cursorX + $parameters.OffsetX + "px");
        }
    } else if((cursorX + $parameters.OffsetX + tooltipWidth) > viewport_width) {
        if($parameters.PositionRelativeToParent) {
            $parameters.TooltipObj.style.left = window.event.currentTarget.offsetWidth - tooltipWidth + "px";
        }else {
            $parameters.TooltipObj.style.left = viewport_width - tooltipWidth + "px";
        }
    } else {
        $parameters.TooltipObj.style.left = "0px";
    }

    //Set Y axis coordinates
    if(((cursorY + $parameters.OffsetY +  tooltipHeight) <= viewport_height) && cursorY + $parameters.OffsetY >= 0) {
        if($parameters.PositionRelativeToParent) {
            $parameters.TooltipObj.style.top = relativeCursorY + $parameters.OffsetY + "px";
        } else {
            $parameters.TooltipObj.style.top = cursorY + $parameters.OffsetY + "px";
        }
    } else if((cursorY + $parameters.OffsetY +  tooltipHeight) > viewport_height) {
        if($parameters.PositionRelativeToParent) {
            $parameters.TooltipObj.style.top = window.event.currentTarget.offsetHeight - tooltipHeight + "px";
        }else {
            $parameters.TooltipObj.style.top = viewport_height - tooltipHeight + "px";
        }
    } else {
        $parameters.TooltipObj.style.top = "0px";
    }
    
} else if($parameters.TooltipObj === document.elementFromPoint(window.event.clientX, window.event.clientY)) { //Detects false positive mouseleave events
    return;
} else {
    //Makes tooltip invisible
    $parameters.TooltipObj.style.display= "none";
}

};
});


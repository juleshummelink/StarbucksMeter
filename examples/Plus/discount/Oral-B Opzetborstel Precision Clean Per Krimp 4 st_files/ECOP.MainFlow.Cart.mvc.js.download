Controller.prototype._handler_SaveToShoppingList$Action = function (callContext) {
var model = this.model;
var controller = this.controller;
var idService = this.idService;
controller.ensureControllerAlive("Handler_SaveToShoppingList");
callContext = controller.callContext(callContext);
var cart_GetItemsListVar = new OS.DataTypes.VariableHolder();
// User logged in?
if((((OS.BuiltinFunctions.getUserId()) !== (OS.BuiltinFunctions.nullIdentifier())))) {
// Execute Action: Cart_GetItemsList
cart_GetItemsListVar.value = ECP_Cart_CWController.default.cart_GetItemsList$Action(callContext);

// Products_InCart = Cart_GetItemsList.ItemsList
model.variables.products_InCartVar = OS.DataConversion.JSConversions.typeConvertRecordList(cart_GetItemsListVar.value.itemsListOut, new ECOPModel.MyCart_LineItemList(), function (source, target) {
target.lineItemIdAttr = source.lineItemIdAttr;
target.sKUAttr = source.sKUAttr;
target.quantityAttr = source.quantityAttr;
target.nameAttr = source.nameAttr;
target.slugAttr = source.slugAttr;
target.imageURLAttr = source.imageAttr.uRLAttr;
target.imageLabelAttr = source.imageAttr.labelAttr;
target.channelIdAttr = source.channelIdAttr;
target.priceAttr = source.priceAttr;
return target;
});
// No Shopping Lists?
if((!(model.variables.getDataDataAct.hasShoppingListsOut))) {
// Execute Action: JS_ExecuteObjFunction2
ECOP_Base_RPatController.default.jS_ExecuteObjFunction$Action(model.variables.createShopList_TogglePopup_JSVar, callContext);
} else {
// Execute Action: JS_ExecuteObjFunction
ECOP_Base_RPatController.default.jS_ExecuteObjFunction$Action(model.variables.addToShopList_TogglePopup_JSVar, callContext);
}

} else {
// Raise Error: NotRegistered
throw new OS.Exceptions.Exceptions.NotRegisteredException("NotRegistered", "User not logged in.");
}

};

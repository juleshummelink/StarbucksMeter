define("ECOP_Reactive_Pat.CustomPatterns.PLPListItem.mvc$controller.ResetHideTimeout.ResetTimeoutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

clearTimeout($parameters.TimeoutId);
$parameters.NewTimeoutId = setTimeout(function(){
     $actions.ToggleSlider(false); 
},$parameters.TimeToShowSliderActive);
};
});

define("ECOP_Reactive_Pat.CustomPatterns.PLPListItem.mvc$controller.OnDestroy.JavaScript1JS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let addProdEl = document.getElementById($parameters.AddProductLink_Id);
if(addProdEl){
    addProdEl.removeEventListener("click", $actions.QuantityOnClick);
}
};
});
define("ECOP_Reactive_Pat.CustomPatterns.PLPListItem.mvc$controller.OnDestroy.ClearTimeOutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
clearTimeout($parameters.TimeoutId);
};
});
define("ECOP_Reactive_Pat.CustomPatterns.PLPListItem.mvc$controller.OnReady.AddEventListenersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let sliderContent = document.getElementById($parameters.SliderId);

if(sliderContent) {
    sliderContent.addEventListener('click', function(e){
        $actions.ResetHideTimeout();
        if(e.target.closest('.btn, a') === null || (e.target === sliderContent)){
            e.stopPropagation();        
        }
    });

    //Add Remove pattern middle column click 
    let middleColumn = sliderContent.querySelector(".add-remove_middle-column");
    if(middleColumn) {
        middleColumn.addEventListener("click", function() {
            $actions.ResetHideTimeout();
        });
    }
}


let addProdEl = document.getElementById($parameters.AddProductLink_Id);
if(addProdEl){
    addProdEl.addEventListener("click", $actions.QuantityOnClick);
}


};
});
define("ECOP_Reactive_Pat.CustomPatterns.PLPListItem.mvc$controller.OnClick_CartListItem.IsDisabledJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let listItem = document.getElementById($parameters.BlockId);

// Check if the list item element has a child element with the class "disable-link"
$parameters.IsDisabled = listItem.classList.contains('disable-link')
};
});


define("ECOP_Reactive_Pat.CustomPatterns.CartListItem.mvc$controller.ResetHideTimeout.ResetTimeoutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {

clearTimeout($parameters.TimeoutId);
$parameters.NewTimeoutId = setTimeout(function(){
     $actions.ToggleSlider(false); 
},$parameters.TimeToShowSliderActive);
};
});
define("ECOP_Reactive_Pat.CustomPatterns.CartListItem.mvc$controller.QuantityOnClick.StopPropagationJS", [], function () {
return function ($actions, $roles, $public) {
event.stopPropagation();
event.preventDefault();
};
});
define("ECOP_Reactive_Pat.CustomPatterns.CartListItem.mvc$controller.Slider_TouchEnd.ResetTimeoutJS", [], function () {

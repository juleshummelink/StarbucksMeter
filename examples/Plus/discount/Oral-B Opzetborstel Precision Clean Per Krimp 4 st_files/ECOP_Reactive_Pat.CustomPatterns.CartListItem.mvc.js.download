define("ECOP_Reactive_Pat.CustomPatterns.CartListItem.mvc$controller.OnReady.AddEventListenersJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let sliderContent = document.getElementById($parameters.SliderId);

if(sliderContent) {
    //Stop progapation
    sliderContent.addEventListener('click', function(e){
        $actions.ResetHideTimeout();
        if(e.target.closest('.btn, a') === null){
            e.stopPropagation();        
        }
    });
    //Add Remove pattern middle column click 
    let middleColumn = sliderContent.querySelector(".add-remove_middle-column");
    if(middleColumn) {
        middleColumn.addEventListener("click", function() {
            $actions.ResetHideTimeout();
        });
    }
}


        
};
});
define("ECOP_Reactive_Pat.CustomPatterns.CartListItem.mvc$controller.OnDestroy.ClearTimeOutJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
clearTimeout($parameters.TimeoutId);
};
});

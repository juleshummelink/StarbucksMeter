define("PLUS_OutSystemsUI_2_8_0.Interaction.Sidebar_v2.mvc$controller.OnReady.SelectionOverflowFixJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let sidebar = document.querySelector('[name="' + $parameters.uniqueId + '"]');
if(sidebar.id !== "") {
    sidebar.addEventListener('click', function (e) {
        
        let sidebar = document.querySelector('[name="' + $parameters.uniqueId + '"]');
        const sidebarId = sidebar.parentElement.id;
        if(sidebar === (e.target)){
            e.preventDefault();
            e.stopPropagation();
        }
        
        if (
            e.target.tagName.toLowerCase() === 'aside' &&
            e.view.window.getSelection().type === "Caret" &&
             e.view.window.getSelection().anchorNode.nodeName !== "SPAN" &&
            e.offsetX < 0
            ) {
            $actions.SidebarClose(sidebarId);
        }
    });
}

};

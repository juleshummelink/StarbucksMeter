define("ECOP_FE_Core.controller$GTMEvent_ViewCart.GTMTriggerJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
try{
    dataLayer.push({ ecommerce: null });  // Clear the previous ecommerce object.
    dataLayer.push({
        'event': 'view_cart',
        'ecommerce': {
            'view_cart': { 
                'currency': "EUR",
                'value': $parameters.TotalPrice,
                'items': JSON.parse($parameters.ItemsList)
            }
        }
    });
}catch(e){
    console.log('Unable to send view_cart event to GTM.');
}
};
});


define("ECOP_FE_Core.controller$GTM_Checkout_InjectStepURL.InjectStepURLJS", [], function () {
return function ($parameters, $actions, $roles, $public) {
let hostUrl = window.location.host;
let filteredPart;
let currentUrl
//Removes '/' if existant
hostUrl = hostUrl.endsWith('/')
            ? hostUrl.slice(0, -1)
            :hostUrl

if($parameters.IsMobile) {
    const pathnameUrl = window.location.pathname;
    const pathParts = pathnameUrl.split('/');
    filteredPart = pathParts.filter(part => part.length > 0)[0] || '';
    
    currentUrl = hostUrl + '/' + filteredPart  + '/checkout/';
} else {
    currentUrl = hostUrl + '/checkout/';
}


//Formats the CurrentStep to fit the URL structure
    let currentStep = $parameters.CurrentStep.toLowerCase().replace(/\s+/g, '-');

// Constructs the new URL and pushes it to the window.history
    let newUrl = window.location.protocol + '//' + currentUrl + currentStep; 
    window.history.replaceState({}, '', newUrl);
};
});


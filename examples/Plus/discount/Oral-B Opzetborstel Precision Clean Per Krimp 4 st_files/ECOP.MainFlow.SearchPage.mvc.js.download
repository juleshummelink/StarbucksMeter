}

// FilterQueryURL = FilterText + SortText
model.variables.filterQueryURLVar = (model.variables.filterTextVar + model.variables.sortTextVar);
controller.safeExecuteJSNode(ECOP_MainFlow_SearchPage_mvc_controller_ManageURLChange_ShowContentJS, "ShowContent", "ManageURLChange", null, function ($parameters) {
